@page "/read/{ComicId:int}/{ChapterId:int}/{PageNumber:int}"
@using HydrusComicCompanion.Services
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusApiService ApiService
@inject IHydrusMediaService MediaService

<PageTitle>Reader</PageTitle>

@if (_isLoading)
{
    <div class="reader-shell reader-shell--loading">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="reader-shell reader-shell--error">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="reader-alert">
            @_errorMessage
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBackToComic">
            Back to comic
        </MudButton>
    </div>
}
else if (_series is not null && _chapter is not null && _currentPage is not null)
{
    <div class="reader-click-zone reader-click-zone--previous" @onclick="GoPreviousAsync"></div>
    <div class="reader-click-zone reader-click-zone--next" @onclick="GoNextAsync"></div>
    <div class="reader-shell"
         tabindex="0"
         @ref="_readerSurface"
         @onkeydown="HandleKeyDown"
         @onkeydown:preventDefault="true"
         @onkeydown:stopPropagation="true"
         @onwheel="HandleWheelAsync"
         @onwheel:preventDefault="true">

        @* Preload all variant images to ensure instant, lag-free CSS flips *@
        <div style="position: absolute; width: 0; height: 0; overflow: hidden; visibility: hidden;" aria-hidden="true">
            @foreach (var variant in CurrentVariants)
            {
                <img src="@MediaService.BuildRenderUrl(variant.FileHash)" alt="" />
            }
        </div>

        <MudPaper Class="reader-topbar" Elevation="4">
            <div class="reader-topbar__title">
                @if (_currentPageTags.Count > 0)
                {
                    <MudStack Row>
                        <MudIconButton Icon="@Icons.Material.Filled.Home" OnClick="GoBackHome"></MudIconButton>
                        <MudExpansionPanels>
                            <MudExpansionPanel Text="@($"{_series.Title} {GetChapterSummary(_chapter)}")" @bind-Expanded="ShowTags">
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="reader-topbar__tags">
                                    @foreach (var tag in _currentPageTags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                                    }
                                </MudStack>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    </MudStack>
                }
                else
                {
                    <MudStack Row>
                        <MudIconButton Icon="@Icons.Material.Filled.Home" OnClick="GoBackHome"></MudIconButton>
                        <MudText Typo="Typo.subtitle1">@_series.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @GetChapterSummary(_chapter)
                        </MudText>
                    </MudStack>
                }
            </div>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="reader-topbar__controls">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Color="Color.Inherit"
                               Variant="Variant.Text"
                               Disabled="@PreviousDisabled"
                               OnClick="GoPreviousAsync"
                               aria-label="Previous page" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Color="Color.Inherit"
                               Variant="Variant.Text"
                               Disabled="@NextDisabled"
                               OnClick="GoNextAsync"
                               aria-label="Next page" />
                <MudDivider Vertical="true" FlexItem="true" />
                <MudText Typo="Typo.body2">Page @_currentPageNumber of @_pages.Count</MudText>
                <MudDivider Vertical="true" FlexItem="true" />
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.MenuBook" OnClick="GoBackToComic">
                    Comic
                </MudButton>
                @if (CurrentVariants.Count > 1)
                {
                    <MudSpacer></MudSpacer>
                    <MudTooltip Text="@GetVariantDisplayName(_currentVariant ?? CurrentVariants[0])" Placement="Placement.Left">
                        <MudIconButton Icon="@Icons.Material.Outlined.ChangeCircle"
                                       Color="Color.Inherit"
                                       Disabled="@_isVariantChanging"
                                       OnClick="CycleNextVariantAsync" />
                    </MudTooltip>
                }
            </MudStack>
        </MudPaper>

        <div class="flip-container @(_isFlipped ? "flipped" : "")" @onclick="CycleNextVariantAsync">
            <div class="flipper">
                <div class="front">
                    @if (_frontVariant is not null)
                    {
                        <img class="reader-page reader-page--front @(CurrentVariants.Count > 1 ? "reader-page--animated-border" : "")"
                             src="@MediaService.BuildRenderUrl(_frontVariant.FileHash)"
                             alt="@GetPageAltText()"
                             draggable="false" />
                    }
                </div>
                <div class="back">
                    @if (_backVariant is not null)
                    {
                        <img class="reader-page reader-page--back @(CurrentVariants.Count > 1 ? "reader-page--animated-border" : "")"
                             src="@MediaService.BuildRenderUrl(_backVariant.FileHash)"
                             alt="@GetPageAltText()"
                             draggable="false" />
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ComicId { get; set; }

    [Parameter]
    public int ChapterId { get; set; }

    [Parameter]
    public int PageNumber { get; set; }

    [Parameter]
    public bool ShowTags { get; set; }

    private ElementReference _readerSurface;
    private ComicsRecord? _series;
    private ChapterRecord? _chapter;
    private IReadOnlyList<PageRecord> _pages = Array.Empty<PageRecord>();
    private PageRecord? _currentPage;
    private PageVariantRecord? _currentVariant;
    private PageVariantRecord? _frontVariant;
    private PageVariantRecord? _backVariant;
    private readonly Dictionary<int, int> _selectedVariantByPageId = [];
    private IReadOnlyList<string> _currentPageTags = Array.Empty<string>();
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _currentPageNumber;
    private bool _isFlipped;
    private bool _isVariantChanging;
    private bool _syncUrlAfterRender;
    private int _syncedSeriesId;
    private int _syncedChapterId;
    private int _syncedPageNumber;
    private DateTime _lastScrollNavigationAt = DateTime.MinValue;

    private bool HasPrevious => GetPreviousPageTarget() is not null;
    private bool PreviousDisabled => !HasPrevious;
    private bool HasNext => GetNextPageTarget() is not null;
    private bool NextDisabled => !HasNext;

    private IReadOnlyList<PageVariantRecord> CurrentVariants => _currentPage is null
        ? []
        : _currentPage.Variants
            .OrderByDescending(v => v.IsDefault)
            .ThenBy(v => v.Label, StringComparer.OrdinalIgnoreCase)
            .ThenBy(v => v.Id)
            .ToList();

    protected override async Task OnParametersSetAsync()
    {
        await LoadReaderAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await _readerSurface.FocusAsync();
            }
            catch
            {
                // No-op if focus cannot be set yet.
            }
        }

        if (_syncUrlAfterRender)
        {
            _syncUrlAfterRender = false;
            NavigationManager.NavigateTo(BuildReaderUrl(_syncedSeriesId, _syncedChapterId, _syncedPageNumber), replace: true);
        }
    }

    private async Task LoadReaderAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _series = null;
        _chapter = null;
        _pages = Array.Empty<PageRecord>();
        _currentPage = null;
        _currentVariant = null;
        _currentPageNumber = 0;
        _isFlipped = false; // Reset flip state for new page
        _isVariantChanging = false; // Reset lock

        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            _series = await context.Comic
                .AsNoTracking()
                .Include(x => x.Chapters)
                    .ThenInclude(x => x.Pages)
                        .ThenInclude(x => x.Variants)
                .SingleOrDefaultAsync(x => x.Id == ComicId);

            if (_series is null)
            {
                _errorMessage = "This title is not in the local cache yet.";
                return;
            }

            var orderedChapters = _series.Chapters
                .OrderBy(x => x.VolumeNumber ?? int.MinValue)
                .ThenBy(x => x.ChapterNumber ?? decimal.MinValue)
                .ThenBy(x => x.Id)
                .ToList();

            _chapter = orderedChapters.FirstOrDefault(x => x.Id == ChapterId)
                ?? orderedChapters.FirstOrDefault();

            if (_chapter is null)
            {
                _errorMessage = "This title does not contain any cached chapters yet.";
                return;
            }

            var orderedPages = _chapter.Pages
                .OrderBy(x => x.PageNumber)
                .ThenBy(x => x.Id)
                .ToList();

            _pages = orderedPages;

            if (_pages.Count == 0)
            {
                _errorMessage = "This chapter does not contain any cached pages yet.";
                return;
            }

            var targetPageNumber = PageNumber;
            if (targetPageNumber < 1)
            {
                targetPageNumber = 1;
            }
            else if (targetPageNumber > _pages.Count)
            {
                targetPageNumber = _pages.Count;
            }

            _currentPage = _pages[targetPageNumber - 1];
            _currentPageNumber = targetPageNumber;

            var variants = CurrentVariants;
            if (_currentPage is not null && variants.Count > 0)
            {
                if (_selectedVariantByPageId.TryGetValue(_currentPage.Id, out var selectedVariantId))
                {
                    _currentVariant = variants.FirstOrDefault(v => v.Id == selectedVariantId)
                        ?? variants.FirstOrDefault(v => v.IsDefault)
                        ?? variants[0];
                }
                else
                {
                    _currentVariant = variants.FirstOrDefault(v => v.IsDefault)
                        ?? variants[0];
                }

                _selectedVariantByPageId[_currentPage.Id] = _currentVariant.Id;
                _currentPageTags = await LoadCurrentPageTagsAsync(_currentVariant.FileHash);

                // Initialize the front and back faces
                _frontVariant = _currentVariant;
                _backVariant = GetNextVariant(_currentVariant);
            }
            else
            {
                _currentVariant = null;
                _frontVariant = null;
                _backVariant = null;
                _currentPageTags = Array.Empty<string>();
            }

            _syncedSeriesId = _series.Id;
            _syncedChapterId = _chapter.Id;
            _syncedPageNumber = _currentPageNumber;

            if (_syncedChapterId != ChapterId || _syncedPageNumber != PageNumber)
            {
                _syncUrlAfterRender = true;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load reader: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task GoPreviousAsync()
    {
        var previousTarget = GetPreviousPageTarget();
        if (previousTarget is null)
        {
            return Task.CompletedTask;
        }

        NavigateToTarget(previousTarget.Value.chapter, previousTarget.Value.pageNumber);
        return Task.CompletedTask;
    }

    private Task GoNextAsync()
    {
        var nextTarget = GetNextPageTarget();
        if (nextTarget is null)
        {
            return Task.CompletedTask;
        }

        NavigateToTarget(nextTarget.Value.chapter, nextTarget.Value.pageNumber);
        return Task.CompletedTask;
    }

    private (ChapterRecord chapter, int pageNumber)? GetPreviousPageTarget()
    {
        if (_chapter is null || _pages.Count == 0)
        {
            return null;
        }

        if (_currentPageNumber > 1)
        {
            return (_chapter, _currentPageNumber - 1);
        }

        var previousChapter = GetOrderedChapters().TakeWhile(x => x.Id != _chapter.Id).LastOrDefault();
        if (previousChapter is null)
        {
            return null;
        }

        var previousChapterPages = previousChapter.Pages
            .OrderBy(x => x.PageNumber)
            .ThenBy(x => x.Id)
            .ToList();

        if (previousChapterPages.Count == 0)
        {
            return null;
        }

        return (previousChapter, previousChapterPages.Count);
    }

    private (ChapterRecord chapter, int pageNumber)? GetNextPageTarget()
    {
        if (_chapter is null || _pages.Count == 0)
        {
            return null;
        }

        if (_currentPageNumber < _pages.Count)
        {
            return (_chapter, _currentPageNumber + 1);
        }

        var orderedChapters = GetOrderedChapters();
        var currentIndex = orderedChapters.FindIndex(x => x.Id == _chapter.Id);
        if (currentIndex < 0 || currentIndex >= orderedChapters.Count - 1)
        {
            return null;
        }

        var nextChapter = orderedChapters[currentIndex + 1];
        var nextChapterPages = nextChapter.Pages
            .OrderBy(x => x.PageNumber)
            .ThenBy(x => x.Id)
            .ToList();

        if (nextChapterPages.Count == 0)
        {
            return null;
        }

        return (nextChapter, 1);
    }

    private List<ChapterRecord> GetOrderedChapters()
    {
        return _series is null
            ? []
            : _series.Chapters
                .OrderBy(x => x.VolumeNumber ?? int.MinValue)
                .ThenBy(x => x.ChapterNumber ?? decimal.MinValue)
                .ThenBy(x => x.Id)
                .ToList();
    }

    private void NavigateToTarget(ChapterRecord chapter, int pageNumber)
    {
        NavigationManager.NavigateTo(BuildReaderUrl(ComicId, chapter.Id, pageNumber));
    }

    private void GoBackToComic()
    {
        NavigationManager.NavigateTo($"/comic/{ComicId}");
    }

    private void GoBackHome()
    {
        NavigationManager.NavigateTo($"/");
    }

    private static string BuildReaderUrl(int seriesId, int chapterId, int pageNumber)
    {
        return $"/read/{seriesId}/{chapterId}/{pageNumber}";
    }

    private string GetVariantDisplayName(PageVariantRecord variant)
    {
        if (variant.IsDefault)
        {
            return string.IsNullOrWhiteSpace(variant.Label)
                ? "Default"
                : $"Default · {variant.Label}";
        }

        return string.IsNullOrWhiteSpace(variant.Label)
            ? $"Variant {variant.Id}"
            : variant.Label;
    }

    private PageVariantRecord? GetNextVariant(PageVariantRecord? referenceVariant)
    {
        if (_currentPage is null || CurrentVariants.Count == 0 || referenceVariant is null)
        {
            return null;
        }
        var currentIndex = CurrentVariants.IndexOf(referenceVariant);
        var nextIndex = (currentIndex + 1) % CurrentVariants.Count;
        return CurrentVariants[nextIndex];
    }

    private async Task CycleNextVariantAsync()
    {
        if (_currentPage is null || CurrentVariants.Count < 2 || _isVariantChanging)
        {
            return;
        }

        _isVariantChanging = true;

        try
        {
            var nextVariant = GetNextVariant(_currentVariant);
            if (nextVariant is null) return;

            // Update core application state tracking
            _currentVariant = nextVariant;
            _selectedVariantByPageId[_currentPage.Id] = nextVariant.Id;

            // Trigger the CSS flip animation immediately
            _isFlipped = !_isFlipped;

            // Fetch metadata in parallel with the animation
            var tagLoadingTask = LoadCurrentPageTagsAsync(nextVariant.FileHash);

            // Allow the UI to process the _isFlipped change so the animation begins
            StateHasChanged();

            // Wait exactly the length of the CSS transition (0.6s) to ensure the card finishes rotating
            await Task.Delay(600);

            // Now that the rotation is done, secretly prepare the *hidden* face for the next cycle
            // This prevents images from snapping/changing visually mid-flip when cycling through >2 variants
            if (_isFlipped)
            {
                _frontVariant = GetNextVariant(_currentVariant);
            }
            else
            {
                _backVariant = GetNextVariant(_currentVariant);
            }

            _currentPageTags = await tagLoadingTask;
        }
        finally
        {
            _isVariantChanging = false;
        }
    }

    private string GetPageAltText()
    {
        if (_series is null || _chapter is null)
        {
            return "Comic page";
        }

        return $"{_series.Title} - {GetChapterSummary(_chapter)} Page {_currentPageNumber}";
    }

    private async Task<IReadOnlyList<string>> LoadCurrentPageTagsAsync(string fileHash)
    {
        try
        {
            var metadata = await ApiService.GetFileMetadataByHashesAsync(new List<string> { fileHash });
            var pageMetadata = metadata.FirstOrDefault();
            return pageMetadata is null
                ? Array.Empty<string>()
                : pageMetadata.GetAllStorageTags().OrderBy(tag => tag, StringComparer.OrdinalIgnoreCase).ToArray();
        }
        catch
        {
            return Array.Empty<string>();
        }
    }

    private static string GetChapterSummary(ChapterRecord chapter)
    {
        var volume = chapter.VolumeNumber.HasValue ? $"Volume {chapter.VolumeNumber.Value}" : "No volume";
        var chapterNumber = chapter.ChapterNumber.HasValue ? $"Chapter {chapter.ChapterNumber.Value:0.##}" : "Flat pages";
        var title = string.IsNullOrWhiteSpace(chapter.Title) ? string.Empty : $" · {chapter.Title}";

        return $"{volume} · {chapterNumber}{title}";
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "ArrowLeft" or "PageUp" or "BrowserBack")
        {
            await GoPreviousAsync();
        }
        else if (args.Key is "ArrowRight" or "PageDown" or "BrowserForward")
        {
            await GoNextAsync();
        }
        else if (args.Key is "Escape")
        {
            GoBackToComic();
        }
    }

    private async Task HandleWheelAsync(WheelEventArgs args)
    {
        if (_isLoading || _currentPage is null)
        {
            return;
        }

        var dominantDelta = Math.Abs(args.DeltaY) >= Math.Abs(args.DeltaX)
            ? args.DeltaY
            : args.DeltaX;

        if (Math.Abs(dominantDelta) < 20)
        {
            return;
        }

        if (DateTime.UtcNow - _lastScrollNavigationAt < TimeSpan.FromMilliseconds(180))
        {
            return;
        }

        _lastScrollNavigationAt = DateTime.UtcNow;

        if (dominantDelta > 0)
        {
            await GoNextAsync();
        }
        else
        {
            await GoPreviousAsync();
        }
    }
}