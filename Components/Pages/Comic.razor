@page "/comic/{ComicId:int}"
@using HydrusComicCompanion.Models
@using HydrusComicCompanion.Services
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusSyncService SyncService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IHydrusApiService ApiService
@inject IHydrusSettingsService SettingsService

<PageTitle>Title</PageTitle>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_comic is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        This comic is not in the local cache yet.
    </MudAlert>
    <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
}
else
{
    <MudStack Spacing="3" Class="pa-4">
        <MudPaper Class="pa-4" Outlined="true">
            <MudOverlay @bind-Visible="_isSyncingMetadata" DarkBackground="true" Absolute="true">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
            </MudOverlay>
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Comic Details</MudText>
                    @if (!_isEditingDetails)
                    {
                        <MudSpacer></MudSpacer>
                        <MudIconButton Icon="@Icons.Material.Filled.Sync"
                                       aria-label="sync"
                                       Size="Size.Small"
                                       OnClick="SyncComic" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       aria-label="edit"
                                       Size="Size.Small"
                                       OnClick="BeginEditDetails" />
                    }
                </MudStack>
                @if (_isEditingDetails)
                {
                    <MudTextField @bind-Value="_displayTitleInput"
                                  Label="Full Title"
                                  Immediate="true"
                                  ReadOnly="@(!_isEditingDetails)" />
                    <MudTextField @bind-Value="_commentInput"
                                  Label="Comment"
                                  Lines="4"
                                  Immediate="true"
                                  ReadOnly="@(!_isEditingDetails)" />
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                        <MudButton Variant="Variant.Outlined"
                                   Disabled="@_isSavingDetails"
                                   OnClick="CancelEditDetails">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@_isSavingDetails"
                                   OnClick="SaveDetailsAsync">
                            @(_isSavingDetails ? "Saving..." : "Save Details")
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="@Typo.caption">Title</MudText>
                    <MudText>@_displayTitleInput</MudText>
                    <MudText Typo="@Typo.caption">Comments</MudText>
                    <MudText>@_commentInput</MudText>
                }
            </MudStack>
        </MudPaper>
        <MudPaper Class="pa-4" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Metadata</MudText>
                @if (_comic.Metadata.Count == 0)
                {
                    <MudText Color="Color.Secondary">No metadata cached yet.</MudText>
                }
                else
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var item in _comic.Metadata)
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Href="@($"./?tag={Uri.EscapeDataString($"{@item.Key}:{item.Value}")}")">@item.Key: @item.Value</MudChip>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
        <MudPaper Class="pa-4" Outlined="true">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">Chapters</MudText>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.EditNote"
                               Disabled="@_isOpeningMetadataEditor"
                               OnClick="OpenMetadataEditorAsync">
                        @(_isOpeningMetadataEditor ? "Opening..." : "Edit Hydrus Metadata")
                    </MudButton>
                </MudStack>
                @if (_orderedChapters.Count == 0)
                {
                    <MudText Color="Color.Secondary">No chapters cached yet.</MudText>
                }
                else
                {
                    <MudStack Spacing="2">
                        <MudGrid Spacing="3">
                            @foreach (var chapter in PagedChapters)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="3">
                                    <ChapterCard
                                        ChapterLabel="@GetChapterLabel(chapter)"
                                        PreviewFileHash="@GetChapterPreviewHash(chapter)"
                                        PageCount="@chapter.Pages.Count"
                                        CanRead="@chapter.Pages.Any()"
                                        OnRead="() => OpenReader(chapter.Id)" />
                                </MudItem>
                            }
                        </MudGrid>

                        @if (TotalChapterPages > 1)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap: 12px;">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Showing @ChapterStartIndex-@ChapterEndIndex of @_orderedChapters.Count chapters
                                </MudText>
                                <MudPagination Count="@TotalChapterPages"
                                               Selected="@_chapterPage"
                                               SelectedChanged="OnChapterPageChanged" />
                            </MudStack>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
        <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
    </MudStack>
}

@code {
    [Parameter]
    public int ComicId { get; set; }

    private const int ChapterPageSize = 12;

    private ComicsRecord? _comic;
    private List<ChapterRecord> _orderedChapters = [];
    private bool _isLoading = true;
    private int _chapterPage = 1;
    private bool _showVolumeInLabel;
    private bool _showChapterInLabel;
    private bool _isEditingDetails;
    private bool _isSavingDetails;
    private bool _isOpeningMetadataEditor;
    bool _isSyncingMetadata { get; set; }
    private string _displayTitleInput = string.Empty;
    private string _commentInput = string.Empty;
    private readonly DialogOptions _center = new() { Position = DialogPosition.Center, FullWidth = true, MaxWidth = MaxWidth.Large};

    protected override async Task OnInitializedAsync()
    {
        await ReloadComicAsync();
        _isLoading = false;
    }

    private int TotalChapterPages => _orderedChapters.Count == 0
        ? 0
        : (int)Math.Ceiling(_orderedChapters.Count / (double)ChapterPageSize);

    private int ChapterStartIndex => _orderedChapters.Count == 0 ? 0 : ((_chapterPage - 1) * ChapterPageSize) + 1;

    private int ChapterEndIndex => Math.Min(_chapterPage * ChapterPageSize, _orderedChapters.Count);

    private IEnumerable<ChapterRecord> PagedChapters => _orderedChapters
        .Skip((_chapterPage - 1) * ChapterPageSize)
        .Take(ChapterPageSize);

    private static int GetTotalPageCount(ComicsRecord comics)
    {
        return comics.Chapters.Sum(chapter => chapter.Pages.Count);
    }

    private static string? GetChapterPreviewHash(ChapterRecord chapter)
    {
        return chapter.Pages
            .OrderBy(x => x.PageNumber)
            .ThenBy(x => x.Id)
            .SelectMany(page => page.Variants
                .OrderByDescending(variant => variant.IsDefault)
                .ThenBy(variant => variant.Id)
                .Take(1))
            .Select(variant => variant.FileHash)
            .FirstOrDefault();
    }

    private string GetChapterLabel(ChapterRecord chapter)
    {
        var labelParts = new List<string>(2);

        if (_showVolumeInLabel)
        {
            labelParts.Add(chapter.VolumeNumber.HasValue
                ? $"Volume {chapter.VolumeNumber.Value}"
                : "Volumeless");
        }

        if (_showChapterInLabel)
        {
            labelParts.Add(chapter.ChapterNumber.HasValue
                ? $"Chapter {chapter.ChapterNumber.Value:0.##}"
                : "Flat pages");
        }

        return string.Join(" · ", labelParts);
    }

    private void BeginEditDetails()
    {
        _isEditingDetails = true;
    }

    private async void SyncComic()
    {
        if (string.IsNullOrEmpty(_comic?.Title)) return;
        _isSyncingMetadata = true;
        await SyncService.SyncComicAsync(_comic.Title);
        _isSyncingMetadata = false;
        StateHasChanged(); // without the MudOverlay stays open
    }

    private void CancelEditDetails()
    {
        if (_comic is null)
        {
            return;
        }

        _displayTitleInput = _comic.DisplayTitle ?? string.Empty;
        _commentInput = _comic.Comment ?? string.Empty;
        _isEditingDetails = false;
    }

    private async Task SaveDetailsAsync()
    {
        if (_comic is null)
        {
            return;
        }

        _isSavingDetails = true;

        try
        {
            var settings = await SettingsService.GetSettingsAsync();
            await using var context = await DbContextFactory.CreateDbContextAsync();

            var series = await context.Comic
                .Include(x => x.Chapters)
                .ThenInclude(x => x.Pages)
                .ThenInclude(x => x.Variants)
                .SingleOrDefaultAsync(x => x.Id == _comic.Id);

            if (series is null)
            {
                Snackbar.Add("Comic not found in local cache.", Severity.Error);
                return;
            }

            var fallbackCoverHash = series.Chapters
                .SelectMany(chapter => chapter.Pages)
                .OrderBy(page => page.PageNumber)
                .ThenBy(page => page.Id)
                .SelectMany(page => page.Variants
                    .OrderByDescending(variant => variant.IsDefault)
                    .ThenBy(variant => variant.Id)
                    .Take(1))
                .Select(variant => variant.FileHash)
                .FirstOrDefault();

            var coverHash = string.IsNullOrWhiteSpace(series.CoverFileHash)
                ? fallbackCoverHash
                : series.CoverFileHash;

            if (string.IsNullOrWhiteSpace(coverHash))
            {
                Snackbar.Add("No cover page found to store title/comment notes.", Severity.Warning);
                return;
            }

            var displayTitle = _displayTitleInput.Trim();
            var comment = _commentInput.Trim();

            await ApiService.SetNotesAsync(
                coverHash,
                new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                {
                    [settings.FullTitleNoteName] = displayTitle,
                    [settings.ComicCommentNoteName] = comment
                },
                mergeCleverly: false,
                cancellationToken: CancellationToken.None);

            series.DisplayTitle = string.IsNullOrWhiteSpace(displayTitle) ? null : displayTitle;
            series.Comment = string.IsNullOrWhiteSpace(comment) ? null : comment;
            series.CoverFileHash = coverHash;

            await context.SaveChangesAsync();

            _comic.DisplayTitle = series.DisplayTitle;
            _comic.Comment = series.Comment;
            _comic.CoverFileHash = series.CoverFileHash;
            _displayTitleInput = _comic.DisplayTitle ?? string.Empty;
            _commentInput = _comic.Comment ?? string.Empty;
            _isEditingDetails = false;

            Snackbar.Add("Comic details saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save comic details: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSavingDetails = false;
        }
    }

    private async Task ReloadComicAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        _comic = await context.Comic
            .AsNoTracking()
            .Include(x => x.Metadata)
            .Include(x => x.Chapters)
                .ThenInclude(x => x.Pages)
                    .ThenInclude(x => x.Variants)
            .SingleOrDefaultAsync(x => x.Id == ComicId);

        _orderedChapters = _comic?.Chapters
            .OrderBy(x => x.VolumeNumber ?? int.MinValue)
            .ThenBy(x => x.ChapterNumber ?? decimal.MinValue)
            .ToList() ?? [];

        _displayTitleInput = _comic?.DisplayTitle ?? string.Empty;
        _commentInput = _comic?.Comment ?? string.Empty;

        _showVolumeInLabel = _orderedChapters
            .Select(x => x.VolumeNumber)
            .Distinct()
            .Count() > 1;

        _showChapterInLabel = _orderedChapters
            .Select(x => x.ChapterNumber)
            .Distinct()
            .Count() > 1;

        _chapterPage = 1;
    }

    private HydrusMetadataEditDialogModel BuildMetadataEditDialogModel()
    {
        var model = new HydrusMetadataEditDialogModel
        {
            ComicId = ComicId,
            HydrusTitle = _comic?.Title ?? string.Empty,
            CoverFileHash = _comic?.CoverFileHash
        };

        var logicalGroupId = 1;
        var chapterStartIndices = new HashSet<int>();
        var volumeStarts = new Dictionary<int, int>();

        var chapterOffset = 0;
        foreach (var chapter in _orderedChapters)
        {
            var orderedPages = chapter.Pages
                .OrderBy(page => page.PageNumber)
                .ThenBy(page => page.Id)
                .ToList();

            if (orderedPages.Count > 0)
            {
                chapterStartIndices.Add(chapterOffset);
            }

            if (chapter.VolumeNumber.HasValue && orderedPages.Count > 0)
            {
                if (!volumeStarts.ContainsKey(chapterOffset))
                {
                    volumeStarts[chapterOffset] = chapter.VolumeNumber.Value;
                }
            }

            foreach (var page in orderedPages)
            {
                var orderedVariants = page.Variants
                    .OrderByDescending(variant => variant.IsDefault)
                    .ThenBy(variant => variant.Id)
                    .ToList();

                for (var variantIndex = 0; variantIndex < orderedVariants.Count; variantIndex++)
                {
                    var variant = orderedVariants[variantIndex];
                    model.Pages.Add(new ImportPage
                    {
                        Index = model.Pages.Count,
                        ArchiveFileName = variant.FileHash,
                        Sha256Hash = variant.FileHash,
                        MimeType = string.IsNullOrWhiteSpace(variant.MimeType) ? "image/jpeg" : variant.MimeType!,
                        PageNumber = page.PageNumber,
                        LogicalPageGroupId = logicalGroupId,
                        IsDefaultVariant = variant.IsDefault,
                        VariantLabel = variant.Label
                    });
                }

                logicalGroupId++;
                chapterOffset += orderedVariants.Count;
            }
        }

        if (chapterStartIndices.Count == 0 && model.Pages.Count > 0)
        {
            chapterStartIndices.Add(0);
        }

        model.ChapterStartIndices = chapterStartIndices;
        model.VolumeStartIndices = volumeStarts;

        if (string.IsNullOrWhiteSpace(model.CoverFileHash))
        {
            model.CoverFileHash = model.Pages
                .FirstOrDefault(page => page.IsDefaultVariant)?.Sha256Hash
                ?? model.Pages.FirstOrDefault()?.Sha256Hash;
        }

        return model;
    }

    private async Task OpenMetadataEditorAsync()
    {
        if (_comic is null)
        {
            return;
        }

        _isOpeningMetadataEditor = true;

        try
        {
            var parameters = new DialogParameters
            {
                [nameof(EditHydrusMetadataDialog.Model)] = BuildMetadataEditDialogModel()
            };

            var dialog = await DialogService.ShowAsync<EditHydrusMetadataDialog>("Edit Hydrus Metadata", parameters, _center);
            var result = await dialog.Result;

            if (result.Canceled || result.Data is not HydrusMetadataEditRequest request)
            {
                return;
            }

            await SyncService.ApplyMetadataEditAsync(request);
            await ReloadComicAsync();
            Snackbar.Add("Hydrus metadata updated.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update Hydrus metadata: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isOpeningMetadataEditor = false;
        }
    }

    private async Task DeleteSeriesAsync()
    {
        if (_comic is null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            [nameof(DeleteComicDialog.Comic)] = _comic.Title
        };

        var dialog = await DialogService.ShowAsync<DeleteComicDialog>("Delete title", parameters, _center);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not bool confirmed || !confirmed)
        {
            return;
        }

        var deleted = await SyncService.DeleteComicAsync(_comic.Id);
        if (!deleted)
        {
            Snackbar.Add("Comic was already removed.", Severity.Warning);
        }
        else
        {
            Snackbar.Add($"Deleted '{_comic.Title}' from cache.", Severity.Success);
        }

        NavigationManager.NavigateTo("/");
    }

    private Task OnChapterPageChanged(int page)
    {
        if (page == _chapterPage)
        {
            return Task.CompletedTask;
        }

        _chapterPage = page;
        return Task.CompletedTask;
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void OpenReader(int chapterId)
    {
        NavigationManager.NavigateTo($"/read/{ComicId}/{chapterId}/1");
    }
}
