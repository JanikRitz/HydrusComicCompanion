@using HydrusComicCompanion.Services
@inject IHydrusMediaService MediaService

<div class="comic-card @(IsClickable ? "comic-card--clickable" : string.Empty)"
     @onclick="HandleClick"
     role="@(IsClickable ? "button" : null)"
     @key=@CoverFileHash>
    <MudCard Outlined="true" Class="comic-card__surface">
        <div class="comic-card__media-wrap">
            @if (!string.IsNullOrWhiteSpace(CoverFileHash))
            {
                <div class="comic-card__media">
                    <HydrusImage Src="@MediaService.BuildRenderUrl(CoverFileHash, width: RenderWidth, height: RenderHeight)"
                                 FullImageSrc="@MediaService.BuildRenderUrl(CoverFileHash)"
                                 Alt="@($"Cover image for {Title}")"
                                 ShowHoverPreview="false"
                                 Loading="lazy" />
                </div>
            }
            else
            {
                <div class="comic-card__placeholder">
                    <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" />
                </div>
            }

            <div class="comic-card__actions" @onclick:stopPropagation="true">
                <div class="comic-card__info-icon">
                    <MudTooltip Text="@LastSyncedLabel">
                        <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Inherit" Variant="Variant.Text" Size="Size.Small" />
                    </MudTooltip>
                </div>

                @if (HasDeleteAction)
                {
                    <div class="comic-card__delete-icon">
                        <MudTooltip Text="Delete from cache">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Inherit" Variant="Variant.Text" Size="Size.Small" OnClick="HandleDelete" />
                        </MudTooltip>
                    </div>
                }
            </div>

            <div class="comic-card__overlay">
                <MudText Typo="Typo.subtitle1" Class="comic-card__title">@Title</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="comic-card__stats">
                    <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.MenuBook">@ChapterCount</MudChip>
                    <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.LocalOffer">@MetadataCount</MudChip>
                    <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.Collections">@TotalPageCount</MudChip>
                </MudStack>
            </div>
        </div>
    </MudCard>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? CoverFileHash { get; set; }

    [Parameter]
    public DateTimeOffset? LastSyncedAt { get; set; }

    [Parameter]
    public int ChapterCount { get; set; }

    [Parameter]
    public int MetadataCount { get; set; }

    [Parameter]
    public int TotalPageCount { get; set; }

    [Parameter]
    public int RenderWidth { get; set; } = 720;

    [Parameter]
    public int RenderHeight { get; set; } = 1080;

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private bool IsClickable => OnClick.HasDelegate;

    private bool HasDeleteAction => OnDelete.HasDelegate;

    private string LastSyncedLabel => LastSyncedAt is null
        ? "Not synced yet"
        : $"Last synced {LastSyncedAt:yyyy-MM-dd HH:mm}";

    private Task HandleClick()
    {
        if (!IsClickable)
        {
            return Task.CompletedTask;
        }

        return OnClick.InvokeAsync();
    }

    private Task HandleDelete()
    {
        if (!HasDeleteAction)
        {
            return Task.CompletedTask;
        }

        return OnDelete.InvokeAsync();
    }
}
