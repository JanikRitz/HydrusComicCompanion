@page "/import"
@using HydrusComicCompanion.Components.ImportWizard.State
@using HydrusComicCompanion.Components.ImportWizard.Steps
@using HydrusComicCompanion.Components.ImportWizard.Services
@using HydrusComicCompanion.Models
@using HydrusComicCompanion.Services
@using HydrusComicCompanion.Services.Abstractions
@inject IComicImportService ComicImportService
@inject ICalibreService CalibreService
@inject IHydrusMediaService HydrusMediaService
@inject IHydrusSyncService SyncService

<PageTitle>Import Comic</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="true">Import Comic</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Choose where your comic content comes from, then follow the import workflow.
        </MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_state.ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">@_state.ErrorMessage</MudAlert>
    }

    @if (_state.HasMultipleQueuedItems
         && _state.CurrentQueueItem is { } currentItem
         && _state.CurrentStep is ImportWizardState.Step.Metadata
            or ImportWizardState.Step.Chapters
            or ImportWizardState.Step.Progress)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            Comic @_state.CurrentQueuePosition of @_state.QueueTotal — @currentItem.DisplayName
        </MudAlert>
    }

    @switch (_state.CurrentStep)
    {
        case ImportWizardState.Step.SourceSelection:
            <SourceSelectionStep SelectedSource="@_state.SelectedSource"
                                 SelectedSourceChanged="@((source) => _state.SetSelectedSource(source))"
                                 OnContinue="@OnSourceSelectionContinue" />
            break;

        case ImportWizardState.Step.Mapping:
            <MappingStep Mapping="@_state.SourceMapping"
                         IsProcessing="@_state.IsDiscovering"
                         OnContinue="@OnMappingContinueAsync"
                         OnBack="@_state.ResetToSourceSelection" />
            break;

        case ImportWizardState.Step.SourceSpecific:
            @if (_state.SelectedSource == ImportSource.Archive)
            {
                <ArchiveSourceStep QueuedItems="@_state.Queue"
                                   IsProcessing="@_state.IsExtracting"
                                   OnFilesSelected="@OnArchivesSelected"
                                   OnRemoveItem="@OnRemoveQueueItem"
                                   OnBegin="@BeginQueueAsync"
                                   OnBack="@OnSourceSpecificBack" />
            }
            else if (_state.SelectedSource is ImportSource.Title)
            {
                <TitleSourceStep QueuedItems="@_state.Queue"
                                 IsProcessing="@_state.IsSyncing"
                                 StepLabel="@TitleStepLabel"
                                 OnAddTitle="@OnAddTitle"
                                 OnRemoveItem="@OnRemoveQueueItem"
                                 OnBegin="@BeginQueueAsync"
                                 OnBack="@OnSourceSpecificBack" />
            }
            else if (_state.SelectedSource is ImportSource.CalibreBook)
            {
                <CalibreSourceStep LibraryPath="@_calibreLibraryPath"
                                   LibraryPathChanged="@((v) => _calibreLibraryPath = v)"
                                   SearchQuery="@_calibreSearchQuery"
                                   SearchQueryChanged="@((v) => _calibreSearchQuery = v)"
                                   DiscoveredBooks="@_calibreDiscoveredBooks"
                                   QueuedItems="@_state.Queue"
                                   IsProcessing="@_state.IsExtracting"
                                   OnDiscover="DiscoverCalibreBooksAsync"
                                   OnAddBook="AddCalibreBookToQueue"
                                   OnQueueAll="QueueAllCalibreBooks"
                                   OnUnqueueAll="UnqueueAllCalibreBooks"
                                   OnRemoveItem="OnRemoveQueueItem"
                                   OnBegin="BeginQueueAsync"
                                   OnBack="OnSourceSpecificBack" />
            }
            break;

        case ImportWizardState.Step.Metadata:
            <MetadataStep TitleName="@_state.TitleName"
                          TitleNameChanged="@((value) => _state.TitleName = value)"
                          DisplayTitle="@_state.DisplayTitle"
                          DisplayTitleChanged="@((value) => _state.DisplayTitle = value)"
                          Comments="@_state.Comments"
                          CommentsChanged="@((value) => _state.Comments = value)"
                          Creator="@_state.Creator"
                          CreatorChanged="@((value) => _state.Creator = value)"
                          CustomTags="@_state.CustomTags"
                          CustomTagsChanged="@((value) => _state.CustomTags = value)"
                          UseChapterTags="@_state.UseChapterTags"
                          UseChapterTagsChanged="@((value) => _state.UseChapterTags = value)"
                          VolumeNumber="@_state.VolumeNumber"
                          VolumeNumberChanged="@((value) => _state.VolumeNumber = value)"
                          PageCount="@MetadataPageCount"
                          PreviewImageSources="@MetadataPreviewImageSources"
                          PreviewImageAlt="@MetadataPreviewImageAlt"
                          ShowSkip="@CanSkipCurrentMetadataItem"
                          OnSkip="@OnMetadataSkipAsync"
                          OnContinue="@OnMetadataContinue"
                          OnBack="@OnMetadataBack" />
            break;

        case ImportWizardState.Step.Chapters:
            <ChapterPlacementStep Pages="@_state.Pages"
                                  PageThumbnails="@_state.PageThumbnailDataUrls"
                                  ChapterStartIndices="@_state.ChapterStartIndices"
                                  UseChapterTags="@_state.UseChapterTags"
                                  VolumeStartIndices="@_state.VolumeStartIndices"
                                  OnChapterStartAdded="@HandleChapterStartAdded"
                                  OnChapterStartRemoved="@HandleChapterStartRemoved"
                                  OnPageMoved="@HandlePageMoved"
                                  OnPageGapAdded="@HandlePageGapAdded"
                                  OnPageGapRemoved="@HandlePageGapRemoved"
                                  OnVolumeStartAdded="@HandleVolumeStartAdded"
                                  OnVolumeStartRemoved="@HandleVolumeStartRemoved"
                                  OnVolumeNumberChanged="@HandleVolumeNumberChanged"
                                  OnGroupWithPrevious="@HandleGroupWithPrevious"
                                  OnUngroupPage="@HandleUngroupPage"
                                  OnDefaultVariantSelected="@HandleDefaultVariantSelected"
                                  OnImport="@StartImportAsync"
                                  OnBack="@_state.GoToMetadata" />
            break;

        case ImportWizardState.Step.Progress:
            <ProgressStep Current="@_state.ProgressCurrent"
                          Total="@_state.ProgressTotal"
                          Message="@_state.ProgressMessage" />
            break;

        case ImportWizardState.Step.Done:
            <CompletedStep Items="@_state.Queue"
                           OnImportAnother="@_state.ResetToSourceSelection" />
            break;
    }
</MudStack>

@code {
    private readonly ImportWizardState _state = new();
    private ThumbnailPreloadService? _thumbnailService;

    private readonly List<CalibreBookEntry> _calibreDiscoveredBooks = [];
    private string _calibreLibraryPath = string.Empty;
    private string _calibreSearchQuery = "formats:true";

    private const long MaxArchiveSizeBytes = 2L * 1024 * 1024 * 1024; // 2 GB

    protected override void OnInitialized()
    {
        _thumbnailService = new ThumbnailPreloadService(HydrusMediaService);
    }

    // ─── Source Selection ───────────────────────────────────────────────

    private void OnSourceSelectionContinue()
    {
        if (_state.SelectedSource == ImportSource.HydrusMapped)
        {
            _state.GoToMapping();
        }
        else
        {
            _state.GoToSourceSpecific();
        }
    }

    // ─── Mapping & Discovery ────────────────────────────────────────────

    private async Task OnMappingContinueAsync()
    {
        _state.ErrorMessage = string.Empty;
        _state.IsDiscovering = true;

        try
        {
            var titlesWithPageCounts = await SyncService.DiscoverMappedTitlesAsync(_state.SourceMapping);
            if (titlesWithPageCounts.Count == 0)
            {
                _state.ErrorMessage = "No comics were discovered with the selected tag service and mapping. Adjust the namespaces and try again.";
                return;
            }

            var minimumPages = _state.SourceMapping.MinimumPages;
            var originalCount = titlesWithPageCounts.Count;

            // If minimum pages is set, show info about the filtering
            if (minimumPages.HasValue && minimumPages > 0)
            {
                var filteredCount = titlesWithPageCounts.Count(t => t.PageCount >= minimumPages);
                if (filteredCount < originalCount)
                {
                    var filteredOut = originalCount - filteredCount;
                    _state.ErrorMessage = $"Discovered {originalCount} comics, but {filteredOut} were filtered out (less than {minimumPages} pages). {filteredCount} comics remain for import.";
                }
                else
                {
                    _state.ErrorMessage = $"Discovered {originalCount} comics. All meet the minimum {minimumPages} page requirement.";
                }
            }
            else
            {
                _state.ErrorMessage = $"Discovered {originalCount} comics ready for import.";
            }

            _state.ReplaceQueueWithMappedTitles(titlesWithPageCounts);
            await BeginQueueAsync();
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Discovery failed: {ex.Message}";
        }
        finally
        {
            _state.IsDiscovering = false;
        }
    }

    private string TitleStepLabel => _state.SelectedSource == ImportSource.HydrusMapped
        ? "Step 3 — Add Hydrus Titles"
        : "Step 2 — Add Hydrus Titles";

    private int? MetadataPageCount => _state.Pages.Count > 0 ? _state.Pages.Count : null;

    private IReadOnlyList<string> MetadataPreviewImageSources => BuildMetadataPreviewImageSources();

    private string MetadataPreviewImageAlt => string.IsNullOrWhiteSpace(_state.CurrentQueueItem?.DisplayName)
        ? "Cover preview"
        : $"{_state.CurrentQueueItem.DisplayName} cover preview";

    private bool CanSkipCurrentMetadataItem => _state.HasMultipleQueuedItems
        && _state.FindNextPendingIndex(_state.CurrentQueueIndex + 1) >= 0;

    private IReadOnlyList<string> BuildMetadataPreviewImageSources()
    {
        if (_state.Pages.Count == 0)
        {
            return Array.Empty<string>();
        }

        return _state.Pages
            .Take(5)
            .Select(BuildPreviewImageSource)
            .Where(source => !string.IsNullOrWhiteSpace(source))
            .Cast<string>()
            .ToArray();
    }

    private string? BuildPreviewImageSource(ImportPage page)
    {
        if (page.Data is { Length: > 0 })
        {
            var mimeType = string.IsNullOrWhiteSpace(page.MimeType) ? "image/jpeg" : page.MimeType;
            return $"data:{mimeType};base64,{Convert.ToBase64String(page.Data)}";
        }

        if (!string.IsNullOrWhiteSpace(page.Sha256Hash))
        {
            return HydrusMediaService.BuildThumbnailUrl(page.Sha256Hash);
        }

        return null;
    }

    private async Task<(ComicImportPreparation Preparation, CalibreMetadataSnapshot Metadata)> ExtractCalibreBookAsync(ImportWizardState.QueuedComic item, CancellationToken cancellationToken)
    {
        var bookId = ParseCalibreBookId(item.Title);
        if (!bookId.HasValue)
        {
            throw new InvalidOperationException($"Invalid Calibre book id in queue item: {item.Title}");
        }

        var libraryPath = (_calibreLibraryPath ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(libraryPath))
        {
            throw new InvalidOperationException("Calibre library path is not set.");
        }

        return await CalibreService.ExtractBookAsync(bookId.Value, libraryPath, cancellationToken);
    }

    private static int? ParseCalibreBookId(string rawValue)
    {
        return int.TryParse((rawValue ?? string.Empty).Trim(), out var parsedId) ? parsedId : null;
    }

    private void ApplyCalibreMetadata(CalibreMetadataSnapshot metadata)
    {
        var seriesOrTitle = !string.IsNullOrWhiteSpace(metadata.Series) ? metadata.Series.Trim() : metadata.Title.Trim();
        if (!string.IsNullOrWhiteSpace(seriesOrTitle))
        {
            _state.TitleName = seriesOrTitle;
        }

        if (!string.IsNullOrWhiteSpace(metadata.Title))
        {
            _state.DisplayTitle = metadata.Title.Trim();
        }

        _state.Creator = metadata.Creator;
        _state.Comments = metadata.Comments;
        _state.VolumeNumber = metadata.VolumeNumber;

        if (metadata.Tags.Count > 0)
        {
            _state.CustomTags = string.Join(", ", metadata.Tags);
        }
    }

    // ─── Queue Building ─────────────────────────────────────────────────

    private void OnArchivesSelected(IReadOnlyList<IBrowserFile> files)
    {
        _state.ErrorMessage = string.Empty;
        _state.ReplaceArchiveQueue(files);
    }

    private void OnAddTitle(string title)
    {
        _state.ErrorMessage = string.Empty;
        _state.AddTitleToQueue(title);
    }

    private async Task DiscoverCalibreBooksAsync()
    {
        _state.ErrorMessage = string.Empty;

        var libraryPath = (_calibreLibraryPath ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(libraryPath))
        {
            _state.ErrorMessage = "A Calibre library path is required.";
            return;
        }

        if (!Directory.Exists(libraryPath))
        {
            _state.ErrorMessage = $"The Calibre library path was not found: {libraryPath}";
            return;
        }

        _state.IsExtracting = true;

        try
        {
            var searchQuery = string.IsNullOrWhiteSpace(_calibreSearchQuery) ? null : _calibreSearchQuery.Trim();
            var books = await CalibreService.DiscoverBooksAsync(libraryPath, searchQuery);

            _calibreDiscoveredBooks.Clear();
            _calibreDiscoveredBooks.AddRange(books);

            _state.ErrorMessage = _calibreDiscoveredBooks.Count == 0
                ? "No Calibre books with CBZ/CBR formats matched your query."
                : $"Discovered {_calibreDiscoveredBooks.Count} Calibre books ready for queueing.";
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Calibre discovery failed: {ex.Message}";
        }
        finally
        {
            _state.IsExtracting = false;
        }
    }

    private void AddCalibreBookToQueue(CalibreBookEntry book)
    {
        _state.ErrorMessage = string.Empty;

        if (_state.Queue.Any(item => item.Source == ImportSource.CalibreBook
            && string.Equals(item.Title, book.Id.ToString(), StringComparison.Ordinal)))
        {
            return;
        }

        _state.Queue.Add(new ImportWizardState.QueuedComic
        {
            Source = ImportSource.CalibreBook,
            Title = book.Id.ToString(),
            DisplayName = book.DisplayName
        });
    }

    private void QueueAllCalibreBooks()
    {
        foreach (var book in _calibreDiscoveredBooks)
        {
            AddCalibreBookToQueue(book);
        }
    }

    private void UnqueueAllCalibreBooks()
    {
        _state.Queue.RemoveAll(item => item.Source == ImportSource.CalibreBook);
    }

    private void OnRemoveQueueItem(ImportWizardState.QueuedComic item)
    {
        _state.RemoveQueueItem(item);
    }

    private void OnSourceSpecificBack()
    {
        if (_state.SelectedSource == ImportSource.HydrusMapped)
        {
            _state.GoToMapping();
        }
        else
        {
            _state.ResetToSourceSelection();
        }
    }

    // ─── Queue Processing ───────────────────────────────────────────────

    private async Task BeginQueueAsync()
    {
        var next = _state.FindNextPendingIndex();
        if (next < 0)
        {
            return;
        }

        _state.CurrentQueueIndex = next;
        await ProcessCurrentItemAsync();
    }

    private async Task ProcessCurrentItemAsync()
    {
        var item = _state.CurrentQueueItem;
        if (item is null)
        {
            return;
        }

        _state.ErrorMessage = string.Empty;

        try
        {
            ComicImportPreparation preparation;
            CalibreMetadataSnapshot? calibreMetadata = null;

            if (item.Source == ImportSource.Archive)
            {
                if (item.ArchiveFile is null)
                {
                    _state.MarkCurrentFailed("Archive file reference is no longer available. Please reselect the files.");
                    await AdvanceOrFinishAsync();
                    return;
                }

                _state.IsExtracting = true;
                await using var stream = item.ArchiveFile.OpenReadStream(maxAllowedSize: MaxArchiveSizeBytes);
                preparation = await ComicImportService.ExtractArchiveAsync(stream, item.ArchiveFile.Name);
            }
            else if (item.Source == ImportSource.CalibreBook)
            {
                _state.IsExtracting = true;
                (preparation, calibreMetadata) = await ExtractCalibreBookAsync(item, CancellationToken.None);
            }
            else
            {
                _state.IsSyncing = true;
                var mapping = item.Source == ImportSource.HydrusMapped ? _state.SourceMapping : null;
                preparation = await SyncService.ExtractComicAsync(item.Title, mapping);
            }

            if (preparation.Pages.Count == 0)
            {
                _state.MarkCurrentFailed(item.Source switch
                {
                    ImportSource.Archive => "No image pages were found in the archive.",
                    ImportSource.CalibreBook => "No image pages were extracted from the selected Calibre archive format.",
                    _ => "No matching files found for that title."
                });
                await AdvanceOrFinishAsync();
                return;
            }

            _state.ApplyPreparation(preparation);

            if (calibreMetadata is not null)
            {
                ApplyCalibreMetadata(calibreMetadata);
            }

            _state.GoToMetadata();
        }
        catch (Exception ex)
        {
            _state.MarkCurrentFailed(ex.Message);
            await AdvanceOrFinishAsync();
        }
        finally
        {
            _state.IsExtracting = false;
            _state.IsSyncing = false;
        }
    }

    private async Task AdvanceOrFinishAsync()
    {
        var next = _state.FindNextPendingIndex(_state.CurrentQueueIndex + 1);
        if (next >= 0)
        {
            _state.CurrentQueueIndex = next;
            await ProcessCurrentItemAsync();
        }
        else
        {
            _state.GoToDone();
        }
    }

    // ─── Metadata Step ──────────────────────────────────────────────────

    private void OnMetadataContinue()
    {
        _state.GoToChapters();
    }

    private async Task OnMetadataSkipAsync()
    {
        _state.MarkCurrentSkipped();
        await AdvanceOrFinishAsync();
    }

    private void OnMetadataBack()
    {
        _state.CurrentQueueIndex = -1;

        if (_state.SelectedSource == ImportSource.HydrusMapped)
        {
            _state.Queue.Clear();
            _state.GoToMapping();
            return;
        }

        _state.ResetToSourceSpecific();
    }

    // ─── Chapter Placement Step ─────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_state.CurrentStep != ImportWizardState.Step.Chapters 
            || !_state.ThumbnailPreloadQueued 
            || _state.IsPreloadingThumbnails 
            || _thumbnailService is null)
        {
            return;
        }

        _state.ThumbnailPreloadQueued = false;
        _state.IsPreloadingThumbnails = true;

        try
        {
            await _thumbnailService.PreloadThumbnailsAsync(
                _state.Pages,
                _state.PageThumbnailDataUrls,
                async () => await InvokeAsync(StateHasChanged),
                () => _state.CurrentStep == ImportWizardState.Step.Chapters
            );
        }
        finally
        {
            _state.IsPreloadingThumbnails = false;
        }
    }

    private void HandleChapterStartAdded(int pageIndex)
    {
        _state.AddChapterStart(pageIndex);
    }

    private void HandleChapterStartRemoved(int pageIndex)
    {
        _state.RemoveChapterStart(pageIndex);
    }

    private void HandlePageMoved((int FromIndex, int ToIndex) move)
    {
        _state.MovePage(move.FromIndex, move.ToIndex);
    }

    private void HandlePageGapAdded(int pageIndex)
    {
        _state.AddPageGap(pageIndex);
    }

    private void HandlePageGapRemoved(int pageIndex)
    {
        _state.RemovePageGap(pageIndex);
    }

    private void HandleVolumeStartAdded((int PageIndex, int VolumeNumber) args)
    {
        _state.AddVolumeStart(args.PageIndex, args.VolumeNumber);
    }

    private void HandleVolumeStartRemoved(int pageIndex)
    {
        _state.RemoveVolumeStart(pageIndex);
    }

    private void HandleVolumeNumberChanged((int PageIndex, int VolumeNumber) args)
    {
        _state.UpdateVolumeNumber(args.PageIndex, args.VolumeNumber);
    }

    private void HandleGroupWithPrevious(int pageIndex)
    {
        _state.GroupWithPreviousPage(pageIndex);
    }

    private void HandleUngroupPage(int pageIndex)
    {
        _state.UngroupPage(pageIndex);
    }

    private void HandleDefaultVariantSelected(int pageIndex)
    {
        _state.SetDefaultVariant(pageIndex);
    }

    // ─── Import Execution ───────────────────────────────────────────────

    private async Task StartImportAsync()
    {
        _state.GoToProgress();

        var request = _state.BuildImportRequest();

        var progress = new Progress<ImportProgressUpdate>(update =>
        {
            _state.UpdateProgress(update);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var seriesId = await ComicImportService.ImportComicAsync(request, progress);
            _state.MarkCurrentImported(seriesId);
            await AdvanceOrFinishAsync();
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Import failed: {ex.Message}";
            _state.CurrentStep = ImportWizardState.Step.Chapters;
            _state.ThumbnailPreloadQueued = true;
        }
    }
}

