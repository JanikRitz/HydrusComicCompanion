@page "/import"
@using HydrusComicCompanion.Components.ImportWizard.State
@using HydrusComicCompanion.Components.ImportWizard.Steps
@using HydrusComicCompanion.Components.ImportWizard.Services
@using HydrusComicCompanion.Models
@using HydrusComicCompanion.Services
@using HydrusComicCompanion.Services.Abstractions
@inject IComicImportService ComicImportService
@inject IHydrusMediaService HydrusMediaService
@inject IHydrusSyncService SyncService

<PageTitle>Import Comic</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="true">Import Comic</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Choose where your comic content comes from, then follow the import workflow.
        </MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_state.ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">@_state.ErrorMessage</MudAlert>
    }

    @switch (_state.CurrentStep)
    {
        case ImportWizardState.Step.SourceSelection:
            <SourceSelectionStep SelectedSource="@_state.SelectedSource"
                                 SelectedSourceChanged="@((source) => _state.SelectedSource = source)"
                                 OnContinue="@_state.GoToSourceSpecific" />
            break;

        case ImportWizardState.Step.SourceSpecific:
            @if (_state.SelectedSource == ImportSource.Archive)
            {
                <ArchiveSourceStep IsProcessing="@_state.IsExtracting"
                                   OnFileSelected="@OnFileSelectedAsync"
                                   OnBack="@_state.ResetToSourceSelection" />
            }
            else if (_state.SelectedSource == ImportSource.Title)
            {
                <TitleSourceStep TitleInput="@_state.TitleInput"
                                 TitleInputChanged="@((value) => _state.TitleInput = value)"
                                 IsProcessing="@_state.IsSyncing"
                                 OnLoadTitle="@LoadHydrusTitleAsync"
                                 OnBack="@_state.ResetToSourceSelection" />
            }
            break;

        case ImportWizardState.Step.Metadata:
            <MetadataStep TitleName="@_state.TitleName"
                          TitleNameChanged="@((value) => _state.TitleName = value)"
                          Creator="@_state.Creator"
                          CreatorChanged="@((value) => _state.Creator = value)"
                          CustomTags="@_state.CustomTags"
                          CustomTagsChanged="@((value) => _state.CustomTags = value)"
                          UseChapterTags="@_state.UseChapterTags"
                          UseChapterTagsChanged="@((value) => _state.UseChapterTags = value)"
                          VolumeNumber="@_state.VolumeNumber"
                          VolumeNumberChanged="@((value) => _state.VolumeNumber = value)"
                          OnContinue="@OnMetadataContinue"
                          OnBack="@_state.ResetToSourceSpecific" />
            break;

        case ImportWizardState.Step.Chapters:
            <ChapterPlacementStep Pages="@_state.Pages"
                                  PageThumbnails="@_state.PageThumbnailDataUrls"
                                  ChapterStartIndices="@_state.ChapterStartIndices"
                                  UseChapterTags="@_state.UseChapterTags"
                                  VolumeStartIndices="@_state.VolumeStartIndices"
                                  OnChapterStartAdded="@HandleChapterStartAdded"
                                  OnChapterStartRemoved="@HandleChapterStartRemoved"
                                  OnPageMoved="@HandlePageMoved"
                                  OnPageGapAdded="@HandlePageGapAdded"
                                  OnPageGapRemoved="@HandlePageGapRemoved"
                                  OnVolumeStartAdded="@HandleVolumeStartAdded"
                                  OnVolumeStartRemoved="@HandleVolumeStartRemoved"
                                  OnVolumeNumberChanged="@HandleVolumeNumberChanged"
                                  OnImport="@StartImportAsync"
                                  OnBack="@_state.GoToMetadata" />
            break;

        case ImportWizardState.Step.Progress:
            <ProgressStep Current="@_state.ProgressCurrent"
                          Total="@_state.ProgressTotal"
                          Message="@_state.ProgressMessage" />
            break;

        case ImportWizardState.Step.Done:
            <CompletedStep ImportedSeriesId="@_state.ImportedSeriesId"
                           OnImportAnother="@_state.ResetToSourceSelection" />
            break;
    }
</MudStack>

@code {
    private readonly ImportWizardState _state = new();
    private ThumbnailPreloadService? _thumbnailService;

    private const long MaxArchiveSizeBytes = 2L * 1024 * 1024 * 1024; // 2 GB

    protected override void OnInitialized()
    {
        _thumbnailService = new ThumbnailPreloadService(HydrusMediaService);
    }

    // ─── Source-Specific Handlers ───────────────────────────────────────

    private async Task OnFileSelectedAsync(IBrowserFile file)
    {
        _state.ErrorMessage = string.Empty;
        _state.IsExtracting = true;

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: MaxArchiveSizeBytes);

            var preparation = await ComicImportService.ExtractArchiveAsync(stream, file.Name);
            if (preparation.Pages.Count == 0)
            {
                _state.ErrorMessage = "No image pages were found in the archive.";
                return;
            }

            _state.ApplyPreparation(preparation);
            _state.GoToMetadata();
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Failed to read archive: {ex.Message}";
        }
        finally
        {
            _state.IsExtracting = false;
        }
    }

    private async Task LoadHydrusTitleAsync(string titleInput)
    {
        _state.IsSyncing = true;
        _state.ErrorMessage = string.Empty;

        try
        {
            var preparation = await SyncService.ExtractTitleAsync(titleInput);
            if (preparation.Pages.Count == 0)
            {
                _state.ErrorMessage = "No matching files found for that title.";
                _state.CurrentStep = ImportWizardState.Step.SourceSpecific;
                return;
            }

            _state.ApplyPreparation(preparation);
            _state.GoToMetadata();
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Failed to load Hydrus title: {ex.Message}";
            _state.CurrentStep = ImportWizardState.Step.SourceSpecific;
        }
        finally
        {
            _state.IsSyncing = false;
        }
    }

    // ─── Metadata Step ──────────────────────────────────────────────────

    private void OnMetadataContinue()
    {
        _state.GoToChapters();
    }

    // ─── Chapter Placement Step ─────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_state.CurrentStep != ImportWizardState.Step.Chapters 
            || !_state.ThumbnailPreloadQueued 
            || _state.IsPreloadingThumbnails 
            || _thumbnailService is null)
        {
            return;
        }

        _state.ThumbnailPreloadQueued = false;
        _state.IsPreloadingThumbnails = true;

        try
        {
            await _thumbnailService.PreloadThumbnailsAsync(
                _state.Pages,
                _state.PageThumbnailDataUrls,
                async () => await InvokeAsync(StateHasChanged),
                () => _state.CurrentStep == ImportWizardState.Step.Chapters
            );
        }
        finally
        {
            _state.IsPreloadingThumbnails = false;
        }
    }

    private void HandleChapterStartAdded(int pageIndex)
    {
        _state.AddChapterStart(pageIndex);
    }

    private void HandleChapterStartRemoved(int pageIndex)
    {
        _state.RemoveChapterStart(pageIndex);
    }

    private void HandlePageMoved((int FromIndex, int ToIndex) move)
    {
        _state.MovePage(move.FromIndex, move.ToIndex);
    }

    private void HandlePageGapAdded(int pageIndex)
    {
        _state.AddPageGap(pageIndex);
    }

    private void HandlePageGapRemoved(int pageIndex)
    {
        _state.RemovePageGap(pageIndex);
    }

    private void HandleVolumeStartAdded((int PageIndex, int VolumeNumber) args)
    {
        _state.AddVolumeStart(args.PageIndex, args.VolumeNumber);
    }

    private void HandleVolumeStartRemoved(int pageIndex)
    {
        _state.RemoveVolumeStart(pageIndex);
    }

    private void HandleVolumeNumberChanged((int PageIndex, int VolumeNumber) args)
    {
        _state.UpdateVolumeNumber(args.PageIndex, args.VolumeNumber);
    }

    // ─── Import Execution ───────────────────────────────────────────────

    private async Task StartImportAsync()
    {
        _state.GoToProgress();

        var request = _state.BuildImportRequest();

        var progress = new Progress<ImportProgressUpdate>(update =>
        {
            _state.UpdateProgress(update);
            InvokeAsync(StateHasChanged);
        });

        try
        {
            _state.ImportedSeriesId = await ComicImportService.ImportComicAsync(request, progress);
            _state.GoToDone();
        }
        catch (Exception ex)
        {
            _state.ErrorMessage = $"Import failed: {ex.Message}";
            _state.CurrentStep = ImportWizardState.Step.Chapters;
            _state.ThumbnailPreloadQueued = true;
        }
    }
}
