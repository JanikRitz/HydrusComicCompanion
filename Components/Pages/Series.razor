@page "/series/{SeriesId:int}"
@using HydrusComicCompanion.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager

<PageTitle>Series</PageTitle>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_series is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        This series is not in the local cache yet.
    </MudAlert>
    <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
}
else
{
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.h4" GutterBottom="true">@_series.Title</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                @(_series.LastSyncedAt is null ? "Not synced yet" : $"Last synced {_series.LastSyncedAt:yyyy-MM-dd HH:mm}")
            </MudText>
        </div>

        <MudPaper Class="pa-4" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Metadata</MudText>
                @if (_series.Metadata.Count == 0)
                {
                    <MudText Color="Color.Secondary">No metadata cached yet.</MudText>
                }
                else
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var item in _series.Metadata)
                        {
                            <MudChip T="string" Variant="Variant.Outlined">@item.Key: @item.Value</MudChip>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        <MudPaper Class="pa-4" Outlined="true">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Chapters</MudText>
                @if (_series.Chapters.Count == 0)
                {
                    <MudText Color="Color.Secondary">No chapters cached yet.</MudText>
                }
                else
                {
                    <MudTable Items="_series.Chapters.OrderBy(x => x.VolumeNumber).ThenBy(x => x.ChapterNumber)" Dense="true">
                        <HeaderContent>
                            <MudTh>Volume</MudTh>
                            <MudTh>Chapter</MudTh>
                            <MudTh>Title</MudTh>
                            <MudTh>Pages</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="chapter">
                            <MudTd DataLabel="Volume">@chapter.VolumeNumber</MudTd>
                            <MudTd DataLabel="Chapter">@chapter.ChapterNumber</MudTd>
                            <MudTd DataLabel="Title">@(chapter.Title ?? "-")</MudTd>
                            <MudTd DataLabel="Pages">@chapter.Pages.Count</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudStack>
        </MudPaper>

        <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
    </MudStack>
}

@code {
    [Parameter]
    public int SeriesId { get; set; }

    private SeriesRecord? _series;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        _series = await context.Series
            .AsNoTracking()
            .Include(x => x.Metadata)
            .Include(x => x.Chapters)
                .ThenInclude(x => x.Pages)
            .SingleOrDefaultAsync(x => x.Id == SeriesId);
        _isLoading = false;
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}
