@page "/series/{SeriesId:int}"
@using HydrusComicCompanion.Services
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusMediaService MediaService
@inject IHydrusSyncService SyncService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Title</PageTitle>

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_series is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        This title is not in the local cache yet.
    </MudAlert>
    <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
}
else
{
    <MudStack Spacing="3" Class="pa-4">
        <MudGrid>
            <MudItem xs="12" sm="12" md="6" lg="6" xl="3">
                <ComicSeriesCard
                    Title="@_series.Title"
                    CoverFileHash="@_series.CoverFileHash"
                    LastSyncedAt="@_series.LastSyncedAt"
                    ChapterCount="@_series.Chapters.Count"
                    MetadataCount="@_series.Metadata.Count"
                    TotalPageCount="@GetTotalPageCount(_series)"
                    RenderWidth="840"
                    RenderHeight="1260"
                    OnDelete="DeleteSeriesAsync" />
            </MudItem>
            <MudItem xs="12" sm="12" md="6" lg="6" xl="3">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Metadata</MudText>
                        @if (_series.Metadata.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No metadata cached yet.</MudText>
                        }
                        else
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var item in _series.Metadata)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined">@item.Key: @item.Value</MudChip>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="12" md="12" lg="12" xl="6">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Chapters</MudText>
                        @if (_series.Chapters.Count == 0)
                        {
                            <MudText Color="Color.Secondary">No chapters cached yet.</MudText>
                        }
                        else
                        {
                            <MudTable Items="_series.Chapters.OrderBy(x => x.VolumeNumber ?? int.MinValue).ThenBy(x => x.ChapterNumber ?? decimal.MinValue)" Dense="true">
                                <HeaderContent>
                                    <MudTh>Preview</MudTh>
                                    <MudTh>Volume</MudTh>
                                    <MudTh>Chapter</MudTh>
                                    <MudTh>Title</MudTh>
                                    <MudTh>Pages</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate Context="chapter">
                                    <MudTd DataLabel="Preview">
                                        @{
                                            var previewHash = chapter.Pages
                                                .OrderBy(x => x.PageNumber)
                                                .Select(x => x.FileHash)
                                                .FirstOrDefault();
                                        }
                                        @if (!string.IsNullOrWhiteSpace(previewHash))
                                        {
                                            <img src="@MediaService.BuildRenderUrl(previewHash, width: 200, height: 200)"
                                                 alt="@($"Preview for {GetChapterLabel(chapter)}")"
                                                 style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px; display:block;" />
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Volume">@(chapter.VolumeNumber?.ToString() ?? "-")</MudTd>
                                    <MudTd DataLabel="Chapter">@(chapter.ChapterNumber?.ToString("0.##") ?? "Flat")</MudTd>
                                    <MudTd DataLabel="Title">@(chapter.Title ?? "Flat pages")</MudTd>
                                    <MudTd DataLabel="Pages">@chapter.Pages.Count</MudTd>
                                    <MudTd DataLabel="Read">
                                        <MudButton Variant="Variant.Outlined"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.MenuBook"
                                                   Disabled="@(!chapter.Pages.Any())"
                                                   OnClick="() => OpenReader(chapter.Id)">
                                            Read
                                        </MudButton>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Text" OnClick="GoHome">Back to Library</MudButton>
    </MudStack>
}

@code {
    [Parameter]
    public int SeriesId { get; set; }

    private SeriesRecord? _series;
    private bool _isLoading = true;
    private readonly DialogOptions _topCenter = new() { Position = DialogPosition.TopCenter };

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        _series = await context.Series
            .AsNoTracking()
            .Include(x => x.Metadata)
            .Include(x => x.Chapters)
                .ThenInclude(x => x.Pages)
            .SingleOrDefaultAsync(x => x.Id == SeriesId);
        _isLoading = false;
    }

    private static int GetTotalPageCount(SeriesRecord series)
    {
        return series.Chapters.Sum(chapter => chapter.Pages.Count);
    }

    private static string GetChapterLabel(ChapterRecord chapter)
    {
        var volume = chapter.VolumeNumber.HasValue ? $"Volume {chapter.VolumeNumber.Value}" : "Volumeless";
        var chapterNumber = chapter.ChapterNumber.HasValue ? $"Chapter {chapter.ChapterNumber.Value:0.##}" : "Flat pages";

        return $"{volume} · {chapterNumber}";
    }

    private async Task DeleteSeriesAsync()
    {
        if (_series is null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            [nameof(DeleteSeriesDialog.TitleName)] = _series.Title
        };

        var dialog = await DialogService.ShowAsync<DeleteSeriesDialog>("Delete title", parameters, _topCenter);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not bool confirmed || !confirmed)
        {
            return;
        }

        var deleted = await SyncService.DeleteSeriesAsync(_series.Id);
        if (!deleted)
        {
            Snackbar.Add("Title was already removed.", Severity.Warning);
        }
        else
        {
            Snackbar.Add($"Deleted '{_series.Title}' from cache.", Severity.Success);
        }

        NavigationManager.NavigateTo("/");
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void OpenReader(int chapterId)
    {
        NavigationManager.NavigateTo($"/read/{SeriesId}/{chapterId}/1");
    }
}
