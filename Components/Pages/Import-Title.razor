@page "/import-title"
@using HydrusComicCompanion.Services
@inject IHydrusSyncService SyncService
@inject NavigationManager NavigationManager

<PageTitle>Import</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="true">Import</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Sync a single comic by entering its title (with or without namespace).
        </MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <MudAlert Severity="@_statusSeverity" Variant="Variant.Outlined">@_statusMessage</MudAlert>
    }

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudTextField @bind-Value="_titleInput"
                      Label="Title"
                      Placeholder="title:the sandman or the sandman"
                      Immediate="true"
                      Disabled="@_isImporting"
                      Class="flex-grow-1" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="ImportComicAsync"
                   Disabled="@(_isImporting || string.IsNullOrWhiteSpace(_titleInput))"
                   StartIcon="@Icons.Material.Filled.Download">
            @if (_isImporting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                <span style="margin-left: 8px;">Importing...</span>
            }
            else
            {
                <span>Import</span>
            }
        </MudButton>
    </MudStack>
</MudStack>

@code {
    private string _titleInput = string.Empty;
    private bool _isImporting;
    private string _statusMessage = string.Empty;
    private Severity _statusSeverity = Severity.Info;

    private async Task ImportComicAsync()
    {
        _isImporting = true;
        _statusMessage = string.Empty;

        try
        {
            var comicId = await SyncService.SyncTitleAsync(_titleInput);
            if (comicId is null)
            {
                _statusSeverity = Severity.Warning;
                _statusMessage = "No matching files found for that title.";
                return;
            }

            _statusSeverity = Severity.Success;
            _statusMessage = "Comic synced successfully.";
            NavigationManager.NavigateTo($"/comic/{comicId.Value}");
        }
        catch (Exception ex)
        {
            _statusSeverity = Severity.Error;
            _statusMessage = $"Import failed: {ex.Message}";
        }
        finally
        {
            _isImporting = false;
        }
    }
}
