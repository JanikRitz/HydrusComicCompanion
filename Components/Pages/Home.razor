@page "/"
@using HydrusComicCompanion.Data
@using HydrusComicCompanion.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusSyncService SyncService
@inject IHydrusMediaService MediaService

<PageTitle>Library</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Browse your cached Hydrus comic series.
                </MudText>
            </div>
            <MudButton 
                Variant="Variant.Filled" 
                Color="Color.Primary" 
                OnClick="SyncNow"
                Disabled="@_isSyncing"
                StartIcon="@Icons.Material.Filled.Refresh">
                @if (_isSyncing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span style="margin-left: 8px;">Syncing...</span>
                }
                else
                {
                    <span>Sync Library</span>
                }
            </MudButton>
        </MudStack>
    </div>

    @if (!string.IsNullOrEmpty(_syncError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_syncError
        </MudAlert>
    }

    @if (_syncedSeriesCount.HasValue)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
            <MudStack Spacing="1">
                <div>Sync completed successfully! Synced <strong>@_syncedSeriesCount</strong> series.</div>
                @if (_lastSyncTime.HasValue)
                {
                    <div style="font-size: 0.9em; color: var(--mud-palette-text-secondary);">
                        Last sync: @_lastSyncTime.Value.ToString("yyyy-MM-dd HH:mm:ss")
                    </div>
                }
            </MudStack>
        </MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_series.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No series are cached yet. Use the settings page to connect Hydrus, then add the discovery and sync flow.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var series in _series)
            {
                <MudItem xs="12" sm="6" md="4">
                    <div style="cursor:pointer;" @onclick="() => OpenSeries(series.Id)">
                        <MudCard Outlined="true" Class="h-100">
                            @if (!string.IsNullOrWhiteSpace(series.CoverFileHash))
                            {
                                <img src="@MediaService.BuildThumbnailUrl(series.CoverFileHash)"
                                     alt="@($"Cover image for {series.Title}")"
                                     style="width:100%; height:220px; object-fit:cover; display:block;" />
                            }
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6">@series.Title</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(series.LastSyncedAt is null ? "Not synced yet" : $"Synced {series.LastSyncedAt:yyyy-MM-dd HH:mm}")
                                    </MudText>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        <MudChip T="string" Variant="Variant.Outlined">@series.Chapters.Count chapters</MudChip>
                                        <MudChip T="string" Variant="Variant.Outlined">@series.Metadata.Count metadata tags</MudChip>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    private List<SeriesRecord> _series = [];
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string? _syncError = null;
    private int? _syncedSeriesCount = null;
    private DateTime? _lastSyncTime = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeriesAsync();
    }

    private async Task LoadSeriesAsync()
    {
        try
        {
            _isLoading = true;
            await using var context = await DbContextFactory.CreateDbContextAsync();
            _series = await context.Series
                .AsNoTracking()
                .Include(x => x.Chapters)
                .Include(x => x.Metadata)
                .OrderBy(x => x.Title)
                .ToListAsync();
            _isLoading = false;
        }
        catch (Exception ex)
        {
            _isLoading = false;
            _syncError = $"Error loading series: {ex.Message}";
        }
    }

    private async Task SyncNow()
    {
        _isSyncing = true;
        _syncError = null;
        _syncedSeriesCount = null;

        try
        {
            _syncedSeriesCount = await SyncService.SyncLibraryAsync();
            _lastSyncTime = DateTime.Now;
            await LoadSeriesAsync();
        }
        catch (Exception ex)
        {
            _syncError = $"Sync failed: {ex.Message}";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void OpenSeries(int seriesId)
    {
        NavigationManager.NavigateTo($"/series/{seriesId}");
    }
}
