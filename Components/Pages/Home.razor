@page "/"
@using HydrusComicCompanion.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager

<PageTitle>Library</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Browse your cached Hydrus comic series.
        </MudText>
    </div>

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_series.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No series are cached yet. Use the settings page to connect Hydrus, then add the discovery and sync flow.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="3">
            @foreach (var series in _series)
            {
                <MudItem xs="12" sm="6" md="4">
                    <div style="cursor:pointer;" @onclick="() => OpenSeries(series.Id)">
                        <MudCard Outlined="true" Class="h-100">
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6">@series.Title</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(series.LastSyncedAt is null ? "Not synced yet" : $"Synced {series.LastSyncedAt:yyyy-MM-dd HH:mm}")
                                    </MudText>
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        <MudChip T="string" Variant="Variant.Outlined">@series.Chapters.Count chapters</MudChip>
                                        <MudChip T="string" Variant="Variant.Outlined">@series.Metadata.Count metadata tags</MudChip>
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </div>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    private List<SeriesRecord> _series = [];
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        _series = await context.Series
            .AsNoTracking()
            .Include(x => x.Chapters)
            .Include(x => x.Metadata)
            .OrderBy(x => x.Title)
            .ToListAsync();
        _isLoading = false;
    }

    private void OpenSeries(int seriesId)
    {
        NavigationManager.NavigateTo($"/series/{seriesId}");
    }
}
