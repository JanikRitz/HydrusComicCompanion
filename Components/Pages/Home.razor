@page "/"
@using HydrusComicCompanion.Services
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusSyncService SyncService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Library</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
            </div>
            <MudButton 
                Variant="Variant.Filled" 
                Color="Color.Primary" 
                OnClick="SyncNow"
                Disabled="@_isSyncing"
                StartIcon="@Icons.Material.Filled.Refresh">
                @if (_isSyncing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span style="margin-left: 8px;">Syncing Existing Titles...</span>
                }
                else
                {
                    <span>Sync Existing Titles</span>
                }
            </MudButton>
        </MudStack>
    </div>

    @if (!string.IsNullOrEmpty(_syncError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_syncError
        </MudAlert>
    }

    @if (_syncedComicsCount.HasValue)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
            <MudStack Spacing="1">
                <div>Sync completed successfully! Synced <strong>@_syncedComicsCount</strong> titles.</div>
                @if (_lastSyncTime.HasValue)
                {
                    <div style="font-size: 0.9em; color: var(--mud-palette-text-secondary);">
                        Last sync: @_lastSyncTime.Value.ToString("yyyy-MM-dd HH:mm:ss")
                    </div>
                }
            </MudStack>
        </MudAlert>
    }

    <MudExpansionPanels>
        <MudExpansionPanel Text="Search and filters">
            <MudStack Spacing="2">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Title contains"
                                      @bind-Value="_titleFilter"
                                      Clearable="true"/>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Tag contains"
                                      HelperText="Supports namespace:value and partial matches"
                                      @bind-Value="_tagFilter"
                                      Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Min volumes" @bind-Value="_minVolumes" Min="0" Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Max volumes" @bind-Value="_maxVolumes" Min="0" Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Min chapters" @bind-Value="_minChapters" Min="0" Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Max chapters" @bind-Value="_maxChapters" Min="0" Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Min pages" @bind-Value="_minTotalPages" Min="0" Clearable="true"/>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudNumericField T="int?" Label="Max pages" @bind-Value="_maxTotalPages" Min="0" Clearable="true"/>
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFiltersAsync">Apply filters</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="ResetFiltersAsync" Disabled="@(!HasActiveFilters)">Reset</MudButton>
                </MudStack>
            </MudStack>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_comics.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            @EmptyStateMessage
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="2">
            <MudGrid Spacing="3">
                @foreach (var comic in _comics)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <ComicCard
                            Title="@comic.Title"
                            CoverFileHash="@comic.CoverFileHash"
                            LastSyncedAt="@comic.LastSyncedAt"
                            ChapterCount="@comic.ChapterCount"
                            MetadataCount="@comic.MetadataCount"
                            TotalPageCount="@comic.TotalPageCount"
                            OnClick="() => OpenComic(comic.Id)"
                            OnDelete="() => DeleteComicAsync(comic.Id, comic.Title)" />
                    </MudItem>
                }
            </MudGrid>

            @if (TotalPages > 1)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap: 12px;">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Showing @StartItemIndex-@EndItemIndex of @_totalComicsCount titles
                    </MudText>
                    <MudPagination Count="@TotalPages"
                                   Selected="@_currentPage"
                                   SelectedChanged="OnPageChanged" />
                </MudStack>
            }
        </MudStack>
    }
</MudStack>

@code {
    private sealed class ComicsCardItem
    {
        public int Id { get; init; }
        public string Title { get; init; } = string.Empty;
        public string? CoverFileHash { get; init; }
        public DateTimeOffset? LastSyncedAt { get; init; }
        public int ChapterCount { get; init; }
        public int MetadataCount { get; init; }
        public int TotalPageCount { get; init; }
    }

    private const int PageSize = 12;
    private readonly DialogOptions _topCenter = new() { Position = DialogPosition.TopCenter };

    private List<ComicsCardItem> _comics = [];
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string? _syncError = null;
    private int? _syncedComicsCount = null;
    private DateTime? _lastSyncTime = null;
    private int _currentPage = 1;
    private int _totalComicsCount = 0;
    private int _totalLibraryComicsCount = 0;
    private string _titleFilter = string.Empty;
    private string _tagFilter = string.Empty;
    private int? _minVolumes;
    private int? _maxVolumes;
    private int? _minChapters;
    private int? _maxChapters;
    private int? _minTotalPages;
    private int? _maxTotalPages;

    private int TotalPages => _totalComicsCount == 0
        ? 0
        : (int)Math.Ceiling(_totalComicsCount / (double)PageSize);

    private int StartItemIndex => _totalComicsCount == 0 ? 0 : ((_currentPage - 1) * PageSize) + 1;

    private int EndItemIndex => Math.Min(_currentPage * PageSize, _totalComicsCount);

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_titleFilter) ||
        !string.IsNullOrWhiteSpace(_tagFilter) ||
        _minVolumes.HasValue ||
        _maxVolumes.HasValue ||
        _minChapters.HasValue ||
        _maxChapters.HasValue ||
        _minTotalPages.HasValue ||
        _maxTotalPages.HasValue;

    private string EmptyStateMessage => _totalLibraryComicsCount == 0
        ? "No titles are cached yet. Use the settings page to connect Hydrus, then add the discovery and sync flow."
        : "No titles matched your current search and filters.";

    protected override async Task OnInitializedAsync()
    {
        await LoadComicsAsync();
    }

    private async Task LoadComicsAsync()
    {
        try
        {
            _isLoading = true;
            await using var context = await DbContextFactory.CreateDbContextAsync();

            var query = context.Comic.AsNoTracking();
            _totalLibraryComicsCount = await query.CountAsync();

            if (!string.IsNullOrWhiteSpace(_titleFilter))
            {
                var titleFilter = _titleFilter.Trim();
                query = query.Where(x => EF.Functions.Like(x.Title, $"%{titleFilter}%"));
            }

            if (!string.IsNullOrWhiteSpace(_tagFilter))
            {
                var tagFilter = _tagFilter.Trim();
                var separatorIndex = tagFilter.IndexOf(':');

                if (separatorIndex > 0 && separatorIndex < tagFilter.Length - 1)
                {
                    var namespaceFilter = tagFilter[..separatorIndex].Trim();
                    var valueFilter = tagFilter[(separatorIndex + 1)..].Trim();

                    query = query.Where(x => x.Metadata.Any(m =>
                        EF.Functions.Like(m.Key, $"%{namespaceFilter}%") &&
                        EF.Functions.Like(m.Value, $"%{valueFilter}%")));
                }
                else
                {
                    query = query.Where(x => x.Metadata.Any(m =>
                        EF.Functions.Like(m.Key, $"%{tagFilter}%") ||
                        EF.Functions.Like(m.Value, $"%{tagFilter}%")));
                }
            }

            if (_minVolumes.HasValue)
            {
                var minVolumes = _minVolumes.Value;
                query = query.Where(x => x.Chapters
                    .Where(c => c.VolumeNumber.HasValue)
                    .Select(c => c.VolumeNumber!.Value)
                    .Distinct()
                    .Count() >= minVolumes);
            }

            if (_maxVolumes.HasValue)
            {
                var maxVolumes = _maxVolumes.Value;
                query = query.Where(x => x.Chapters
                    .Where(c => c.VolumeNumber.HasValue)
                    .Select(c => c.VolumeNumber!.Value)
                    .Distinct()
                    .Count() <= maxVolumes);
            }

            if (_minChapters.HasValue)
            {
                var minChapters = _minChapters.Value;
                query = query.Where(x => x.Chapters.Count() >= minChapters);
            }

            if (_maxChapters.HasValue)
            {
                var maxChapters = _maxChapters.Value;
                query = query.Where(x => x.Chapters.Count() <= maxChapters);
            }

            if (_minTotalPages.HasValue)
            {
                var minPages = _minTotalPages.Value;
                query = query.Where(x => x.Chapters.SelectMany(c => c.Pages).Count() >= minPages);
            }

            if (_maxTotalPages.HasValue)
            {
                var maxPages = _maxTotalPages.Value;
                query = query.Where(x => x.Chapters.SelectMany(c => c.Pages).Count() <= maxPages);
            }

            _totalComicsCount = await query.CountAsync();

            if (_totalComicsCount == 0)
            {
                _currentPage = 1;
                _comics = [];
                _isLoading = false;
                return;
            }

            var totalPages = (int)Math.Ceiling(_totalComicsCount / (double)PageSize);
            if (_currentPage > totalPages)
            {
                _currentPage = totalPages;
            }

            var skip = (_currentPage - 1) * PageSize;

            _comics = await query
                .OrderBy(x => x.Title)
                .Skip(skip)
                .Take(PageSize)
                .Select(x => new ComicsCardItem
                {
                    Id = x.Id,
                    Title = x.Title,
                    CoverFileHash = x.CoverFileHash,
                    LastSyncedAt = x.LastSyncedAt,
                    ChapterCount = x.Chapters.Count(),
                    MetadataCount = x.Metadata.Count(),
                    TotalPageCount = x.Chapters.SelectMany(c => c.Pages).Count()
                })
                .ToListAsync();

            _isLoading = false;
        }
        catch (Exception ex)
        {
            _isLoading = false;
            _syncError = $"Error loading titles: {ex.Message}";
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _currentPage = 1;
        await LoadComicsAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _titleFilter = string.Empty;
        _tagFilter = string.Empty;
        _minVolumes = null;
        _maxVolumes = null;
        _minChapters = null;
        _maxChapters = null;
        _minTotalPages = null;
        _maxTotalPages = null;
        _currentPage = 1;
        await LoadComicsAsync();
    }

    private async Task SyncNow()
    {
        _isSyncing = true;
        _syncError = null;
        _syncedComicsCount = null;

        try
        {
            _syncedComicsCount = await SyncService.SyncExistingLibrariesAsync();
            _lastSyncTime = DateTime.Now;
            _currentPage = 1;
            await LoadComicsAsync();
        }
        catch (Exception ex)
        {
            _syncError = $"Sync failed: {ex.Message}";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        if (page == _currentPage)
        {
            return;
        }

        _currentPage = page;
        await LoadComicsAsync();
    }

    private async Task DeleteComicAsync(int comicId, string title)
    {
        var parameters = new DialogParameters
        {
            [nameof(DeleteComicDialog.Comic)] = title
        };

        var dialog = await DialogService.ShowAsync<DeleteComicDialog>("Delete comic", parameters, _topCenter);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not bool confirmed || !confirmed)
        {
            return;
        }

        var deleted = await SyncService.DeleteComicAsync(comicId);
        if (!deleted)
        {
            Snackbar.Add("Title was already removed.", Severity.Warning);
            await LoadComicsAsync();
            return;
        }

        Snackbar.Add($"Deleted '{title}' from cache.", Severity.Success);
        await LoadComicsAsync();
    }

    private void OpenComic(int comicId)
    {
        NavigationManager.NavigateTo($"/comic/{comicId}");
    }
}
