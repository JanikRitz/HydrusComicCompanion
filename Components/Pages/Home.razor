@page "/"

<PageTitle>Library</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Browse your Hydrus comic series. Data sync and real covers will be wired in the next slices.
        </MudText>
    </div>

    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
            <MudText Typo="Typo.h6">Series</MudText>
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">Sync pending</MudChip>
        </MudStack>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No series discovered yet. Once Hydrus integration is connected, series cards will appear here.
    </MudAlert>
</MudStack>
