@page "/"
@using HydrusComicCompanion.Data
@using HydrusComicCompanion.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SettingsDbContext> DbContextFactory
@inject NavigationManager NavigationManager
@inject IHydrusSyncService SyncService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Library</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <div>
                <MudText Typo="Typo.h4" GutterBottom="true">Library</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    Browse your cached Hydrus comics.
                </MudText>
            </div>
            <MudButton 
                Variant="Variant.Filled" 
                Color="Color.Primary" 
                OnClick="SyncNow"
                Disabled="@_isSyncing"
                StartIcon="@Icons.Material.Filled.Refresh">
                @if (_isSyncing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span style="margin-left: 8px;">Syncing Existing Titles...</span>
                }
                else
                {
                    <span>Sync Existing Titles</span>
                }
            </MudButton>
        </MudStack>
    </div>

    @if (!string.IsNullOrEmpty(_syncError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
            @_syncError
        </MudAlert>
    }

    @if (_syncedSeriesCount.HasValue)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
            <MudStack Spacing="1">
                <div>Sync completed successfully! Synced <strong>@_syncedSeriesCount</strong> titles.</div>
                @if (_lastSyncTime.HasValue)
                {
                    <div style="font-size: 0.9em; color: var(--mud-palette-text-secondary);">
                        Last sync: @_lastSyncTime.Value.ToString("yyyy-MM-dd HH:mm:ss")
                    </div>
                }
            </MudStack>
        </MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_series.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No titles are cached yet. Use the settings page to connect Hydrus, then add the discovery and sync flow.
        </MudAlert>
    }
    else
    {
        <MudStack Spacing="2">
            <MudGrid Spacing="3">
                @foreach (var series in _series)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <ComicSeriesCard
                            Title="@series.Title"
                            CoverFileHash="@series.CoverFileHash"
                            LastSyncedAt="@series.LastSyncedAt"
                            ChapterCount="@series.ChapterCount"
                            MetadataCount="@series.MetadataCount"
                            TotalPageCount="@series.TotalPageCount"
                            OnClick="() => OpenSeries(series.Id)"
                            OnDelete="() => DeleteSeriesAsync(series.Id, series.Title)" />
                    </MudItem>
                }
            </MudGrid>

            @if (TotalPages > 1)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap: 12px;">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Showing @StartItemIndex-@EndItemIndex of @_totalSeriesCount titles
                    </MudText>
                    <MudPagination Count="@TotalPages"
                                   Selected="@_currentPage"
                                   SelectedChanged="OnPageChanged" />
                </MudStack>
            }
        </MudStack>
    }
</MudStack>

@code {
    private sealed class SeriesCardItem
    {
        public int Id { get; init; }
        public string Title { get; init; } = string.Empty;
        public string? CoverFileHash { get; init; }
        public DateTimeOffset? LastSyncedAt { get; init; }
        public int ChapterCount { get; init; }
        public int MetadataCount { get; init; }
        public int TotalPageCount { get; init; }
    }

    private const int PageSize = 12;
    private readonly DialogOptions _topCenter = new() { Position = DialogPosition.TopCenter };

    private List<SeriesCardItem> _series = [];
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string? _syncError = null;
    private int? _syncedSeriesCount = null;
    private DateTime? _lastSyncTime = null;
    private int _currentPage = 1;
    private int _totalSeriesCount = 0;

    private int TotalPages => _totalSeriesCount == 0
        ? 0
        : (int)Math.Ceiling(_totalSeriesCount / (double)PageSize);

    private int StartItemIndex => _totalSeriesCount == 0 ? 0 : ((_currentPage - 1) * PageSize) + 1;

    private int EndItemIndex => Math.Min(_currentPage * PageSize, _totalSeriesCount);

    protected override async Task OnInitializedAsync()
    {
        await LoadSeriesAsync();
    }

    private async Task LoadSeriesAsync()
    {
        try
        {
            _isLoading = true;
            await using var context = await DbContextFactory.CreateDbContextAsync();

            _totalSeriesCount = await context.Series
                .AsNoTracking()
                .CountAsync();

            if (_totalSeriesCount == 0)
            {
                _currentPage = 1;
                _series = [];
                _isLoading = false;
                return;
            }

            var totalPages = (int)Math.Ceiling(_totalSeriesCount / (double)PageSize);
            if (_currentPage > totalPages)
            {
                _currentPage = totalPages;
            }

            var skip = (_currentPage - 1) * PageSize;

            _series = await context.Series
                .AsNoTracking()
                .OrderBy(x => x.Title)
                .Skip(skip)
                .Take(PageSize)
                .Select(x => new SeriesCardItem
                {
                    Id = x.Id,
                    Title = x.Title,
                    CoverFileHash = x.CoverFileHash,
                    LastSyncedAt = x.LastSyncedAt,
                    ChapterCount = x.Chapters.Count(),
                    MetadataCount = x.Metadata.Count(),
                    TotalPageCount = x.Chapters.SelectMany(c => c.Pages).Count()
                })
                .ToListAsync();

            _isLoading = false;
        }
        catch (Exception ex)
        {
            _isLoading = false;
            _syncError = $"Error loading titles: {ex.Message}";
        }
    }

    private async Task SyncNow()
    {
        _isSyncing = true;
        _syncError = null;
        _syncedSeriesCount = null;

        try
        {
            _syncedSeriesCount = await SyncService.SyncExistingLibrariesAsync();
            _lastSyncTime = DateTime.Now;
            _currentPage = 1;
            await LoadSeriesAsync();
        }
        catch (Exception ex)
        {
            _syncError = $"Sync failed: {ex.Message}";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task OnPageChanged(int page)
    {
        if (page == _currentPage)
        {
            return;
        }

        _currentPage = page;
        await LoadSeriesAsync();
    }

    private async Task DeleteSeriesAsync(int seriesId, string title)
    {
        var parameters = new DialogParameters
        {
            [nameof(DeleteSeriesDialog.TitleName)] = title
        };

        var dialog = await DialogService.ShowAsync<DeleteSeriesDialog>("Delete title", parameters, _topCenter);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not bool confirmed || !confirmed)
        {
            return;
        }

        var deleted = await SyncService.DeleteSeriesAsync(seriesId);
        if (!deleted)
        {
            Snackbar.Add("Title was already removed.", Severity.Warning);
            await LoadSeriesAsync();
            return;
        }

        Snackbar.Add($"Deleted '{title}' from cache.", Severity.Success);
        await LoadSeriesAsync();
    }

    private void OpenSeries(int comicId)
    {
        NavigationManager.NavigateTo($"/comic/{comicId}");
    }
}
