<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="2">
        <MudText Typo="Typo.h6">Step 3 — Metadata</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Review and edit the metadata. The title tag is added as a Hydrus tag, while display title and comments are saved as Hydrus notes.
        </MudText>

        <MudGrid Spacing="3" AlignItems="AlignItems.Stretch">
            <MudItem xs="12" md="@MetadataColumnMd">
                <MudStack Spacing="2">
                    <MudTextField Value="@TitleName"
                                  ValueChanged="@TitleNameChanged"
                                  Label="Hydrus Title Tag"
                                  Required="true"
                                  Immediate="true"
                                  HelperText="Added as tag title:&lt;value&gt; (e.g. The Sandman)" />

                    <MudTextField Value="@DisplayTitle"
                                  ValueChanged="@DisplayTitleChanged"
                                  Label="Display Title"
                                  Immediate="true"
                                  HelperText="Optional note text for the configured title note (cover page note)" />

                    <MudTextField Value="@Comments"
                                  ValueChanged="@CommentsChanged"
                                  Label="Comments"
                                  Immediate="true"
                                  Lines="4"
                                  HelperText="Optional note text for the configured comment note (cover page note)" />

                    <MudTextField Value="@Creator"
                                  ValueChanged="@CreatorChanged"
                                  Label="Creator"
                                  Immediate="true"
                                  HelperText="e.g. Neil Gaiman (optional)" />

                    <MudTextField Value="@CustomTags"
                                  ValueChanged="@CustomTagsChanged"
                                  Label="Custom Tags"
                                  Immediate="true"
                                  HelperText="Separate tags with commas, e.g. action, drama, sci-fi" />

                    <MudSwitch Value="@UseChapterTags" ValueChanged="@UseChapterTagsChanged" Color="Color.Primary" Label="Use chapter tags" />

                    <MudNumericField T="int?" Value="@VolumeNumber" ValueChanged="@VolumeNumberChanged"
                                     Label="Volume Number"
                                     Clearable="true"
                                     HelperText="Optional" />
                </MudStack>
            </MudItem>
            

            @if (HasPageCount)
            {
            }
            @if (HasPreviewImages || HasPageCount)
            {
                <MudItem xs="12" md="4">
                    <MudStack Spacing="2">
                        @if (HasPageCount)
                        {
                            <MudText Color="Color.Secondary">
                                Discovered @PageCount pages
                            </MudText>
                        }
                        @if (HasPreviewImages)
                        {
                            <MudPaper Outlined="true" Class="pa-2 d-flex align-center justify-center" Style="min-height: 100%;">
                                <img src="@PrimaryPreviewImageSource"
                                     alt="@PreviewImageAlt"
                                     style="width: 100%; max-width: 100%; max-height: 720px; object-fit: contain; display: block;"/>
                            </MudPaper>
                        }
                        @if (ThumbnailPreviewSources.Length > 0)
                        {
                            <MudGrid Spacing="1">
                                @foreach (var thumbnail in ThumbnailPreviewSources)
                                {
                                    <MudItem xs="6">
                                        <MudPaper Outlined="true" Class="pa-1 d-flex align-center justify-center">
                                            <img src="@thumbnail"
                                                 alt="More page preview"
                                                 style="width: 100%; max-height: 140px; object-fit: contain; display: block;" />
                                        </MudPaper>
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </MudStack>
                </MudItem>
            }
        </MudGrid>

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
            <MudButton Variant="Variant.Outlined" OnClick="OnBackClicked">Back</MudButton>
            @if (ShowSkip)
            {
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="OnSkipClicked">Skip Comic</MudButton>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@string.IsNullOrWhiteSpace(TitleName)"
                       OnClick="OnContinueClicked">
                Next: Place Chapters
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public string TitleName { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> TitleNameChanged { get; set; }

    [Parameter]
    public string DisplayTitle { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> DisplayTitleChanged { get; set; }

    [Parameter]
    public string Comments { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CommentsChanged { get; set; }

    [Parameter]
    public string Creator { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CreatorChanged { get; set; }

    [Parameter]
    public string CustomTags { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> CustomTagsChanged { get; set; }

    [Parameter]
    public bool UseChapterTags { get; set; }

    [Parameter]
    public EventCallback<bool> UseChapterTagsChanged { get; set; }

    [Parameter]
    public int? VolumeNumber { get; set; }

    [Parameter]
    public EventCallback<int?> VolumeNumberChanged { get; set; }

    [Parameter]
    public int? PageCount { get; set; }

    [Parameter]
    public IReadOnlyList<string> PreviewImageSources { get; set; } = Array.Empty<string>();

    [Parameter]
    public string PreviewImageAlt { get; set; } = "Cover preview";

    [Parameter]
    public EventCallback OnContinue { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public bool ShowSkip { get; set; }

    [Parameter]
    public EventCallback OnSkip { get; set; }

    private bool HasPageCount => PageCount is > 0;

    private IReadOnlyList<string> ValidPreviewSources => PreviewImageSources.Where(source => !string.IsNullOrWhiteSpace(source)).ToArray();

    private bool HasPreviewImages => ValidPreviewSources.Count > 0;

    private int MetadataColumnMd => HasPreviewImages ? 8 : 12;

    private string? PrimaryPreviewImageSource => ValidPreviewSources.FirstOrDefault();

    private string[] ThumbnailPreviewSources => ValidPreviewSources.Skip(1).Take(4).ToArray();

    private async Task OnContinueClicked()
    {
        await OnContinue.InvokeAsync();
    }

    private async Task OnBackClicked()
    {
        await OnBack.InvokeAsync();
    }

    private async Task OnSkipClicked()
    {
        await OnSkip.InvokeAsync();
    }
}
