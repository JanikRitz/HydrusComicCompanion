@using HydrusComicCompanion.Components.ImportWizard.State

<MudPaper Class="pa-4" Outlined="true">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h6">@StepLabel</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Add one or more titles to load from Hydrus. Each is taken through metadata and page ordering,
            then imported, one after another.
        </MudText>

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_currentTitle"
                          Label="Title"
                          Placeholder="title:the sandman or the sandman"
                          Immediate="true"
                          Disabled="@IsProcessing"
                          OnKeyUp="@OnTitleKeyUp"
                          HelperText="With or without namespace prefix"
                          Class="flex-grow-1" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       OnClick="OnAddClickedAsync"
                       Disabled="@(IsProcessing || string.IsNullOrWhiteSpace(_currentTitle))"
                       StartIcon="@Icons.Material.Filled.Add">
                Add
            </MudButton>
        </MudStack>

        @if (QueuedItems.Count > 0)
        {
            <MudDataGrid T="ImportWizardState.QueuedComic"
                         Items="@QueuedItems"
                         Filterable="true"
                         QuickFilter="@QueueQuickFilter"
                         Dense="true"
                         Hover="true">
                <ToolBarContent>
                    <MudText Typo="Typo.subtitle2">Queued titles</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_queueSearch"
                                  Placeholder="Filter titles"
                                  Adornment="Adornment.Start"
                                  Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Disabled="@IsProcessing"
                                  Class="mt-0" />
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.DisplayName" Title="Title" />
                    <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Disabled="@IsProcessing"
                                           OnClick="@(() => OnRemoveItem.InvokeAsync(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ImportWizardState.QueuedComic" />
                </PagerContent>
            </MudDataGrid>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">No titles added yet.</MudText>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" Spacing="2">
            <MudButton Variant="Variant.Outlined" OnClick="OnBackClicked" Disabled="@IsProcessing">Back</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OnBeginClicked"
                       Disabled="@(IsProcessing || QueuedItems.Count == 0)"
                       StartIcon="@Icons.Material.Filled.PlayArrow">
                @if (IsProcessing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <span style="margin-left: 8px;">Working…</span>
                }
                else
                {
                    <span>Start Import (@QueuedItems.Count)</span>
                }
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<ImportWizardState.QueuedComic> QueuedItems { get; set; } = [];

    [Parameter]
    public bool IsProcessing { get; set; }

    [Parameter]
    public string StepLabel { get; set; } = "Step 2 — Enter Hydrus Titles";

    [Parameter]
    public EventCallback<string> OnAddTitle { get; set; }

    [Parameter]
    public EventCallback<ImportWizardState.QueuedComic> OnRemoveItem { get; set; }

    [Parameter]
    public EventCallback OnBegin { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    private string _currentTitle = string.Empty;
    private string _queueSearch = string.Empty;

    private Func<ImportWizardState.QueuedComic, bool> QueueQuickFilter => item =>
    {
        if (string.IsNullOrWhiteSpace(_queueSearch))
        {
            return true;
        }

        return item.DisplayName.Contains(_queueSearch, StringComparison.OrdinalIgnoreCase)
            || item.Title.Contains(_queueSearch, StringComparison.OrdinalIgnoreCase);
    };

    private async Task OnAddClickedAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentTitle))
        {
            return;
        }

        await OnAddTitle.InvokeAsync(_currentTitle);
        _currentTitle = string.Empty;
    }

    private async Task OnTitleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await OnAddClickedAsync();
        }
    }

    private async Task OnBeginClicked() => await OnBegin.InvokeAsync();

    private async Task OnBackClicked() => await OnBack.InvokeAsync();
}
