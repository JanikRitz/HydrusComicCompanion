@using HydrusComicCompanion.Models

<MudPaper Class="pa-4" Outlined="true" Style="height: calc(100dvh - 220px);">
    <MudStack Spacing="2" Style="height: 100%; min-height: 0;">
        <MudText Typo="Typo.h6">Step 4 — Chapter Placement</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @ChapterPlacementHint
        </MudText>

        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @Pages.Count pages · @ChapterSummary
        </MudText>

        <MudTable Items="@Pages" Dense="true" Hover="true" FixedHeader="true" Height="100%" Style="flex: 1 1 auto; min-height: 0;">
            <HeaderContent>
                <MudTh>Move</MudTh>
                <MudTh>Preview</MudTh>
                <MudTh>Order</MudTh>
                <MudTh>Tag Page #</MudTh>
                <MudTh>File</MudTh>
                <MudTh>Chapter</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                @{ var pageIndex = context.Index; }
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIconButton Icon="@Icons.Material.Filled.DragIndicator"
                                       Variant="Variant.Text"
                                       Color="Color.Default"
                                       draggable="true"
                                       @ondragstart="@(() => OnDragStart(pageIndex))" />
                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                       Disabled="@(pageIndex == 0)"
                                       Size="Size.Small"
                                       Variant="Variant.Text"
                                       OnClick="@(() => OnMoveClicked(pageIndex, pageIndex - 1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                       Disabled="@(pageIndex >= Pages.Count - 1)"
                                       Size="Size.Small"
                                       Variant="Variant.Text"
                                       OnClick="@(() => OnMoveClicked(pageIndex, pageIndex + 1))" />
                    </MudStack>
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @if (PageThumbnails.TryGetValue(pageIndex, out var thumbnailUrl))
                    {
                        <img src="@thumbnailUrl"
                             alt="@($"Preview for page {pageIndex + 1}")"
                             loading="lazy"
                             decoding="async"
                             style="width: 64px; height: 64px; object-fit: cover; border-radius: 4px; display:block;" />
                    }
                    else
                    {
                        <MudSkeleton Width="64px" Height="64px" Animation="Animation.Wave" />
                    }
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">@(pageIndex + 1)</MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    <MudNumericField T="int?"
                                     Value="context.PageNumber"
                                     ValueChanged="@((int? value) => OnPageNumberEdited(pageIndex, value))"
                                     Immediate="true"
                                     Min="1"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Style="max-width:110px;" />
                </MudTd>
                <MudTd Style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @System.IO.Path.GetFileName(context.ArchiveFileName)
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @if (UseChapterTags)
                    {
                        <MudChip T="string"
                                 Color="@(IsChapterStart(pageIndex) ? Color.Primary : Color.Default)"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined">
                            Ch. @GetChapterNumber(pageIndex)
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                            Flat
                        </MudChip>
                    }
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @if (!UseChapterTags)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">No chapter tags</MudText>
                    }
                    else if (pageIndex == 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">Start</MudText>
                    }
                    else if (IsChapterStart(pageIndex))
                    {
                        <MudButton Size="Size.Small"
                                   Color="Color.Error"
                                   Variant="Variant.Text"
                                   OnClick="@(() => OnRemoveChapterStart(pageIndex))">
                            Remove
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   OnClick="@(() => OnAddChapterStart(pageIndex))">
                            New Chapter
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
            <MudButton Variant="Variant.Outlined" OnClick="OnBackClicked">Back</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       OnClick="OnImportClicked">
                Import
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public List<ImportPage> Pages { get; set; } = [];

    [Parameter]
    public Dictionary<int, string> PageThumbnails { get; set; } = [];

    [Parameter]
    public HashSet<int> ChapterStartIndices { get; set; } = [0];

    [Parameter]
    public bool UseChapterTags { get; set; }

    [Parameter]
    public EventCallback<int> OnChapterStartAdded { get; set; }

    [Parameter]
    public EventCallback<int> OnChapterStartRemoved { get; set; }

    [Parameter]
    public EventCallback<(int FromIndex, int ToIndex)> OnPageMoved { get; set; }

    [Parameter]
    public EventCallback<(int PageIndex, int? PageNumber)> OnPageNumberChanged { get; set; }

    [Parameter]
    public EventCallback OnImport { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    private int? _draggedPageIndex;

    private string ChapterPlacementHint => UseChapterTags
        ? "Page 1 starts Chapter 1. Drag pages (or use arrows) to reorder, edit page numbers directly, and set chapter starts as needed."
        : "Chapter tags are disabled. You can still reorder pages and edit page numbers (including gaps).";

    private string ChapterSummary => UseChapterTags
        ? $"{ChapterStartIndices.Count} chapter(s)"
        : "flat pages";

    private bool IsChapterStart(int pageIndex) => ChapterStartIndices.Contains(pageIndex);

    private int GetChapterNumber(int pageIndex)
    {
        var sorted = ChapterStartIndices.OrderBy(i => i).ToList();
        return sorted.Count(s => s <= pageIndex);
    }

    private void OnDragStart(int pageIndex)
    {
        _draggedPageIndex = pageIndex;
    }

    private async Task OnDrop(int targetPageIndex)
    {
        if (!_draggedPageIndex.HasValue)
        {
            return;
        }

        var fromIndex = _draggedPageIndex.Value;
        _draggedPageIndex = null;

        if (fromIndex == targetPageIndex)
        {
            return;
        }

        await OnPageMoved.InvokeAsync((fromIndex, targetPageIndex));
    }

    private async Task OnMoveClicked(int fromIndex, int toIndex)
    {
        if (toIndex < 0 || toIndex >= Pages.Count || fromIndex == toIndex)
        {
            return;
        }

        await OnPageMoved.InvokeAsync((fromIndex, toIndex));
    }

    private async Task OnPageNumberEdited(int pageIndex, int? pageNumber)
    {
        await OnPageNumberChanged.InvokeAsync((pageIndex, pageNumber));
    }

    private async Task OnAddChapterStart(int pageIndex)
    {
        await OnChapterStartAdded.InvokeAsync(pageIndex);
    }

    private async Task OnRemoveChapterStart(int pageIndex)
    {
        await OnChapterStartRemoved.InvokeAsync(pageIndex);
    }

    private async Task OnImportClicked()
    {
        await OnImport.InvokeAsync();
    }

    private async Task OnBackClicked()
    {
        await OnBack.InvokeAsync();
    }
}
