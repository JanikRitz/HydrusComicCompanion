@using HydrusComicCompanion.Models
@using HydrusComicCompanion.Services
@inject IHydrusMediaService MediaService

<MudPaper Class="pa-4" Outlined="true" Style="height: calc(100dvh - 220px);">
    <MudStack Spacing="2" Style="height: 100%; min-height: 0;">
        <MudText Typo="Typo.h6">Step 4 — Chapter Placement</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @ChapterPlacementHint
        </MudText>

        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @LogicalPageCount logical page(s) · @IncludedVariantCount included variant(s) · @ExcludedPageCount excluded · @ChapterSummary
        </MudText>

        <MudTable Items="@Pages" Dense="true" Hover="true" FixedHeader="true" Height="100%" Style="flex: 1 1 auto; min-height: 0;">
            <HeaderContent>
                <MudTh>Move</MudTh>
                <MudTh>Preview</MudTh>
                <MudTh>Page #</MudTh>
                <MudTh>Chapter</MudTh>
                <MudTh>Variant</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                @{ var pageIndex = context.Index; }
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    <MudStack Spacing="0">
                        <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.DragIndicator"
                                           Variant="Variant.Text"
                                           Color="Color.Default"
                                           Disabled="@context.IsExcluded"
                                           draggable="true"
                                           @ondragstart="@(() => OnDragStart(pageIndex))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                           Disabled="@(pageIndex == 0 || context.IsExcluded)"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           OnClick="@(() => OnMoveClicked(pageIndex, pageIndex - 1))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                           Disabled="@(pageIndex >= Pages.Count - 1 || context.IsExcluded)"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           OnClick="@(() => OnMoveClicked(pageIndex, pageIndex + 1))" />
                        </MudStack>
                        @if (UseChapterTags)
                        {
                            <MudStack Row="true" Spacing="0" AlignItems="AlignItems.Center">
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowUp"
                                               Disabled="@(pageIndex == GetChapterStartIndex(pageIndex) || context.IsExcluded)"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Title="Move to chapter start"
                                               OnClick="@(() => OnMoveToChapterStart(pageIndex))" />
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"
                                               Disabled="@(pageIndex == GetChapterEndIndex(pageIndex) || context.IsExcluded)"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Title="Move to chapter end"
                                               OnClick="@(() => OnMoveToChapterEnd(pageIndex))" />
                                @if (VolumeStartIndices.Count > 1)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.VerticalAlignTop"
                                                   Disabled="@(pageIndex == GetVolumeStartIndex(pageIndex) || context.IsExcluded)"
                                                   Size="Size.Small"
                                                   Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   Title="Move to volume start"
                                                   OnClick="@(() => OnMoveToVolumeStart(pageIndex))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.VerticalAlignBottom"
                                                   Disabled="@(pageIndex == GetVolumeEndIndex(pageIndex) || context.IsExcluded)"
                                                   Size="Size.Small"
                                                   Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   Title="Move to volume end"
                                                   OnClick="@(() => OnMoveToVolumeEnd(pageIndex))" />
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @{ var thumbnailUrl = GetThumbnailSource(context, pageIndex); }
                    @if (!string.IsNullOrWhiteSpace(thumbnailUrl))
                    {
                        <HydrusImage Src="@thumbnailUrl"
                                     FullImageSrc="@GetFullImageSource(context, thumbnailUrl)"
                                     Alt="@System.IO.Path.GetFileName(context.ArchiveFileName)"
                                     Loading="lazy"
                                     Decoding="async"
                                     ShowHoverPreview="true"
                                     HoverPlacement="Placement.Right"
                                     title="@System.IO.Path.GetFileName(context.ArchiveFileName)"
                                     Style="width: 64px; height: 64px; object-fit: contain; border-radius: 4px; display:block; cursor:default;" />
                    }
                    else
                    {
                        <MudSkeleton Width="64px" Height="64px" Animation="Animation.Wave" />
                    }
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @if (context.IsExcluded)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Excluded</MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body1">@ComputeFinalPageNumber(pageIndex)</MudText>
                        @if (context.GapBefore > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">+@context.GapBefore gap</MudText>
                        }
                    }
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    @if (UseChapterTags)
                    {
                        @if (VolumeStartIndices.Count > 0)
                        {
                            var vol = GetVolumeNumberForPage(pageIndex);
                            var ch = GetChapterWithinVolumeNumber(pageIndex);
                            <MudChip T="string"
                                     Color="@(IsChapterStart(pageIndex) ? Color.Primary : Color.Default)"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined">
                                @(vol.HasValue ? $"V{vol} " : "")Ch@(ch)
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string"
                                     Color="@(IsChapterStart(pageIndex) ? Color.Primary : Color.Default)"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined">
                                Ch. @GetChapterNumber(pageIndex)
                            </MudChip>
                        }
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                            Flat
                        </MudChip>
                    }
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    <MudStack Spacing="1">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (IsPrimaryVariant(pageIndex))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Primary</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Alternate</MudChip>
                            }

                            @if (context.IsDefaultVariant)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Default</MudChip>
                            }
                            else
                            {
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.StarBorder"
                                               Color="Color.Default"
                                               Title="Set as default variant"
                                               Variant="Variant.Text"
                                               Disabled="@context.IsExcluded"
                                               OnClick="@(() => OnDefaultVariantClicked(pageIndex))" />
                            }
                        </MudStack>

                        @if (CanGroupWithPrevious(pageIndex))
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Disabled="@context.IsExcluded"
                                       OnClick="@(() => OnGroupWithPreviousClicked(pageIndex))">
                                Group with previous
                            </MudButton>
                        }
                        else if (CanUngroup(pageIndex))
                        {
                            <MudTextField @bind-Value="context.VariantLabel"
                                          Label="Variant label"
                                          Immediate="true"
                                          Disabled="@context.IsExcluded"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"/>
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Text"
                                       Color="Color.Warning"
                                       Disabled="@context.IsExcluded"
                                       OnClick="@(() => OnUngroupClicked(pageIndex))">
                                Ungroup
                            </MudButton>
                        }
                    </MudStack>
                </MudTd>
                <MudTd @ondragover:preventDefault="true" @ondrop="@(() => OnDrop(pageIndex))">
                    <MudStack Spacing="1">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   Color="@(context.IsExcluded ? Color.Success : Color.Error)"
                                   OnClick="@(() => OnTogglePageExcluded(pageIndex))">
                            @(context.IsExcluded ? "Include" : "Exclude")
                        </MudButton>
                        @if (!IsPrimaryVariant(pageIndex))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Shared with primary variant</MudText>
                        }
                        else if (UseChapterTags)
                        {
                            @if (IsVolumeStart(pageIndex))
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Vol.</MudText>
                                    <MudNumericField T="int"
                                                     Value="@VolumeStartIndices[pageIndex]"
                                                     ValueChanged="@((int v) => OnVolumeNumberEdited(pageIndex, v))"
                                                     Immediate="true"
                                                     Min="1"
                                                     Disabled="@context.IsExcluded"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Style="max-width:70px;" />
                                    @if (pageIndex > 0)
                                    {
                                        <MudIconButton Size="Size.Small"
                                                       Icon="@Icons.Material.Filled.Close"
                                                       Color="Color.Error"
                                                       Variant="Variant.Text"
                                                       Disabled="@context.IsExcluded"
                                                       Title="Remove volume start"
                                                       OnClick="@(() => OnRemoveVolumeStart(pageIndex))" />
                                    }
                                </MudStack>
                            }
                            else if (pageIndex == 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Tertiary">Start</MudText>
                            }
                            else if (IsChapterStart(pageIndex))
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudButton Size="Size.Small"
                                               Color="Color.Error"
                                               Variant="Variant.Text"
                                               Disabled="@context.IsExcluded"
                                               OnClick="@(() => OnRemoveChapterStart(pageIndex))">
                                        Remove Chapter
                                    </MudButton>
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Upgrade"
                                                   Color="Color.Secondary"
                                                   Variant="Variant.Text"
                                                   Disabled="@context.IsExcluded"
                                                   Title="Promote to volume start"
                                                   OnClick="@(() => OnAddVolumeStart(pageIndex))" />
                                </MudStack>
                            }
                            else
                            {
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small"
                                               Color="Color.Primary"
                                               Variant="Variant.Outlined"
                                               Disabled="@context.IsExcluded"
                                               OnClick="@(() => OnAddChapterStart(pageIndex))">
                                        New Chapter
                                    </MudButton>
                                    <MudButton Size="Size.Small"
                                               Color="Color.Secondary"
                                               Variant="Variant.Outlined"
                                               Disabled="@context.IsExcluded"
                                               OnClick="@(() => OnAddVolumeStart(pageIndex))">
                                        New Volume
                                    </MudButton>
                                </MudStack>
                            }
                        }
                        @if (IsPrimaryVariant(pageIndex) && pageIndex > 0 && (!UseChapterTags || (!IsChapterStart(pageIndex) && !IsVolumeStart(pageIndex))))
                        {
                            @if (context.GapBefore > 0)
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Warning"
                                             Variant="Variant.Outlined">
                                        +@context.GapBefore missing
                                    </MudChip>
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Remove"
                                                   Color="Color.Default"
                                                   Variant="Variant.Text"
                                                   Disabled="@context.IsExcluded"
                                                   Title="Remove one gap"
                                                   OnClick="@(() => OnRemovePageGap(pageIndex))" />
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Add"
                                                   Color="Color.Warning"
                                                   Variant="Variant.Text"
                                                   Disabled="@context.IsExcluded"
                                                   Title="Add another gap"
                                                   OnClick="@(() => OnAddPageGap(pageIndex))" />
                                </MudStack>
                            }
                            else
                            {
                                <MudButton Size="Size.Small"
                                           Color="Color.Default"
                                           Variant="Variant.Outlined"
                                           Disabled="@context.IsExcluded"
                                           OnClick="@(() => OnAddPageGap(pageIndex))">
                                    + Gap
                                </MudButton>
                            }
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (ShowNavigationButtons)
        {
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="Variant.Outlined" OnClick="OnBackClicked">@BackActionLabel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.CloudUpload"
                           Disabled="@(IncludedVariantCount == 0)"
                           OnClick="OnImportClicked">
                    @PrimaryActionLabel
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter]
    public List<ImportPage> Pages { get; set; } = [];

    [Parameter]
    public Dictionary<int, string> PageThumbnails { get; set; } = [];

    [Parameter]
    public HashSet<int> ChapterStartIndices { get; set; } = [0];

    [Parameter]
    public bool UseChapterTags { get; set; }

    [Parameter]
    public EventCallback<int> OnChapterStartAdded { get; set; }

    [Parameter]
    public EventCallback<int> OnChapterStartRemoved { get; set; }

    [Parameter]
    public EventCallback<(int FromIndex, int ToIndex)> OnPageMoved { get; set; }

    [Parameter]
    public EventCallback<int> OnPageGapAdded { get; set; }

    [Parameter]
    public EventCallback<int> OnPageGapRemoved { get; set; }

    [Parameter]
    public Dictionary<int, int> VolumeStartIndices { get; set; } = [];

    [Parameter]
    public EventCallback<(int PageIndex, int VolumeNumber)> OnVolumeStartAdded { get; set; }

    [Parameter]
    public EventCallback<int> OnVolumeStartRemoved { get; set; }

    [Parameter]
    public EventCallback<(int PageIndex, int VolumeNumber)> OnVolumeNumberChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnGroupWithPrevious { get; set; }

    [Parameter]
    public EventCallback<int> OnUngroupPage { get; set; }

    [Parameter]
    public EventCallback<int> OnDefaultVariantSelected { get; set; }

    [Parameter]
    public EventCallback<(int PageIndex, bool IsExcluded)> OnPageExclusionChanged { get; set; }

    [Parameter]
    public EventCallback OnImport { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public bool ShowNavigationButtons { get; set; } = true;

    [Parameter]
    public string BackActionLabel { get; set; } = "Back";

    [Parameter]
    public string PrimaryActionLabel { get; set; } = "Import";

    private int? _draggedPageIndex;

    private string ChapterPlacementHint => UseChapterTags
        ? "Drag pages (or use arrows) to reorder \u2014 page numbers update automatically. Use \u2018New Chapter\u2019 / \u2018New Volume\u2019 to mark boundaries and \u2018+ Gap\u2019 to indicate a missing source page. Double arrows jump to chapter/volume boundaries."
        : "Chapter tags are disabled. Drag pages to reorder. Use \u2018+ Gap\u2019 if a source page is missing to keep tag numbering accurate.";

    private string ChapterSummary => UseChapterTags
        ? VolumeStartIndices.Count > 0
            ? $"{VolumeStartIndices.Count} volume(s) \u00b7 {ChapterStartIndices.Count} chapter(s)"
            : $"{ChapterStartIndices.Count} chapter(s)"
        : "flat pages";

    private int LogicalPageCount => Pages.Where(p => !p.IsExcluded).Select(p => p.LogicalPageGroupId).Distinct().Count();
    private int IncludedVariantCount => Pages.Count(p => !p.IsExcluded);
    private int ExcludedPageCount => Pages.Count(p => p.IsExcluded);

    private string GetFullImageSource(ImportPage page, string fallbackSource)
    {
        if (page.Data is { Length: > 0 })
        {
            var mimeType = string.IsNullOrWhiteSpace(page.MimeType) ? "image/jpeg" : page.MimeType;
            return $"data:{mimeType};base64,{Convert.ToBase64String(page.Data)}";
        }

        if (!string.IsNullOrWhiteSpace(page.Sha256Hash))
        {
            return MediaService.BuildRenderUrl(page.Sha256Hash);
        }

        return fallbackSource;
    }

    private string? GetThumbnailSource(ImportPage page, int pageIndex)
    {
        if (page.Data is { Length: > 0 })
        {
            var mimeType = string.IsNullOrWhiteSpace(page.MimeType) ? "image/jpeg" : page.MimeType;
            return $"data:{mimeType};base64,{Convert.ToBase64String(page.Data)}";
        }

        if (PageThumbnails.TryGetValue(pageIndex, out var thumbnailUrl)
            && !string.IsNullOrWhiteSpace(thumbnailUrl))
        {
            return thumbnailUrl;
        }

        if (!string.IsNullOrWhiteSpace(page.Sha256Hash))
        {
            return MediaService.BuildThumbnailUrl(page.Sha256Hash);
        }

        return null;
    }

    private bool IsChapterStart(int pageIndex) => ChapterStartIndices.Contains(pageIndex);

    private bool IsVolumeStart(int pageIndex) => VolumeStartIndices.ContainsKey(pageIndex);

    private int GetChapterNumber(int pageIndex)
    {
        var sorted = ChapterStartIndices.OrderBy(i => i).ToList();
        return sorted.Count(s => s <= pageIndex);
    }

    private int GetChapterWithinVolumeNumber(int pageIndex)
    {
        if (!UseChapterTags || ChapterStartIndices.Count == 0) return 1;
        var chapterStart = ChapterStartIndices.Where(s => s <= pageIndex).DefaultIfEmpty(0).Max();
        var volumeStart = VolumeStartIndices.Count > 0
            ? VolumeStartIndices.Keys.Where(k => k <= chapterStart).DefaultIfEmpty(0).Max()
            : 0;
        return ChapterStartIndices.Count(s => s >= volumeStart && s <= chapterStart);
    }

    private int? GetVolumeNumberForPage(int pageIndex)
    {
        if (VolumeStartIndices.Count == 0) return null;
        return VolumeStartIndices
            .Where(kv => kv.Key <= pageIndex)
            .OrderByDescending(kv => kv.Key)
            .Select(kv => kv.Value)
            .Cast<int?>()
            .FirstOrDefault();
    }

    private int SuggestNextVolumeNumber()
        => VolumeStartIndices.Count == 0 ? 1 : VolumeStartIndices.Values.Max() + 1;

    // ─── Jump-target helpers ────────────────────────────────────

    private int GetChapterStartIndex(int pageIndex)
    {
        if (!UseChapterTags || ChapterStartIndices.Count == 0) return 0;
        return ChapterStartIndices.Where(s => s <= pageIndex).DefaultIfEmpty(0).Max();
    }

    private int GetChapterEndIndex(int pageIndex)
    {
        if (!UseChapterTags || ChapterStartIndices.Count == 0) return Pages.Count - 1;
        var next = ChapterStartIndices.Where(s => s > pageIndex).OrderBy(s => s).Cast<int?>().FirstOrDefault();
        return next.HasValue ? next.Value - 1 : Pages.Count - 1;
    }

    private int GetVolumeStartIndex(int pageIndex)
    {
        if (VolumeStartIndices.Count == 0) return 0;
        return VolumeStartIndices.Keys.Where(k => k <= pageIndex).DefaultIfEmpty(0).Max();
    }

    private int GetVolumeEndIndex(int pageIndex)
    {
        if (VolumeStartIndices.Count == 0) return Pages.Count - 1;
        var next = VolumeStartIndices.Keys.Where(k => k > pageIndex).OrderBy(k => k).Cast<int?>().FirstOrDefault();
        return next.HasValue ? next.Value - 1 : Pages.Count - 1;
    }

    private void OnDragStart(int pageIndex)
    {
        _draggedPageIndex = pageIndex;
    }

    private async Task OnDrop(int targetPageIndex)
    {
        if (!_draggedPageIndex.HasValue)
        {
            return;
        }

        var fromIndex = _draggedPageIndex.Value;
        _draggedPageIndex = null;

        if (fromIndex == targetPageIndex)
        {
            return;
        }

        await OnPageMoved.InvokeAsync((fromIndex, targetPageIndex));
    }

    private async Task OnMoveClicked(int fromIndex, int toIndex)
    {
        if (toIndex < 0 || toIndex >= Pages.Count || fromIndex == toIndex)
        {
            return;
        }

        await OnPageMoved.InvokeAsync((fromIndex, toIndex));
    }

    private async Task OnMoveToChapterStart(int pageIndex)
    {
        var target = GetChapterStartIndex(pageIndex);
        if (target != pageIndex)
            await OnPageMoved.InvokeAsync((pageIndex, target));
    }

    private async Task OnMoveToChapterEnd(int pageIndex)
    {
        var target = GetChapterEndIndex(pageIndex);
        if (target != pageIndex)
            await OnPageMoved.InvokeAsync((pageIndex, target));
    }

    private async Task OnMoveToVolumeStart(int pageIndex)
    {
        var target = GetVolumeStartIndex(pageIndex);
        if (target != pageIndex)
            await OnPageMoved.InvokeAsync((pageIndex, target));
    }

    private async Task OnMoveToVolumeEnd(int pageIndex)
    {
        var target = GetVolumeEndIndex(pageIndex);
        if (target != pageIndex)
            await OnPageMoved.InvokeAsync((pageIndex, target));
    }

    private async Task OnAddVolumeStart(int pageIndex)
    {
        await OnVolumeStartAdded.InvokeAsync((pageIndex, SuggestNextVolumeNumber()));
    }

    private async Task OnRemoveVolumeStart(int pageIndex)
    {
        await OnVolumeStartRemoved.InvokeAsync(pageIndex);
    }

    private async Task OnVolumeNumberEdited(int pageIndex, int volumeNumber)
    {
        await OnVolumeNumberChanged.InvokeAsync((pageIndex, volumeNumber));
    }

    private async Task OnAddPageGap(int pageIndex)
    {
        await OnPageGapAdded.InvokeAsync(pageIndex);
    }

    private async Task OnRemovePageGap(int pageIndex)
    {
        await OnPageGapRemoved.InvokeAsync(pageIndex);
    }

    private int ComputeFinalPageNumber(int pageIndex)
    {
        if (pageIndex < 0 || pageIndex >= Pages.Count)
        {
            return pageIndex + 1;
        }

        var groupId = Pages[pageIndex].LogicalPageGroupId;
        var primaryIndex = FindPrimaryIncludedVariantIndex(groupId);
        if (primaryIndex < 0)
        {
            return 0;
        }

        var chapterStart = 0;
        if (UseChapterTags && ChapterStartIndices.Count > 0)
        {
            chapterStart = ChapterStartIndices
                .Where(s => s <= primaryIndex)
                .DefaultIfEmpty(0)
                .Max();
        }

        var withinChapterPos = 0;
        var gapCount = 0;
        for (var i = chapterStart; i <= primaryIndex; i++)
        {
            if (!IsPrimaryVariant(i) || Pages[i].IsExcluded)
            {
                continue;
            }

            withinChapterPos++;
            gapCount += Pages[i].GapBefore;
        }

        return withinChapterPos + gapCount;
    }

    private bool IsPrimaryVariant(int pageIndex)
    {
        if (pageIndex < 0 || pageIndex >= Pages.Count)
        {
            return false;
        }

        return FindPrimaryVariantIndex(Pages[pageIndex].LogicalPageGroupId) == pageIndex;
    }

    private int FindPrimaryVariantIndex(int logicalPageGroupId)
    {
        for (var i = 0; i < Pages.Count; i++)
        {
            if (Pages[i].LogicalPageGroupId == logicalPageGroupId)
            {
                return i;
            }
        }

        return 0;
    }

    private int FindPrimaryIncludedVariantIndex(int logicalPageGroupId)
    {
        for (var i = 0; i < Pages.Count; i++)
        {
            if (Pages[i].LogicalPageGroupId == logicalPageGroupId && !Pages[i].IsExcluded)
            {
                return i;
            }
        }

        return -1;
    }

    private bool CanGroupWithPrevious(int pageIndex)
    {
        return pageIndex > 0 && Pages[pageIndex].LogicalPageGroupId != Pages[pageIndex - 1].LogicalPageGroupId;
    }

    private bool CanUngroup(int pageIndex)
    {
        if (pageIndex < 0 || pageIndex >= Pages.Count)
        {
            return false;
        }

        var groupId = Pages[pageIndex].LogicalPageGroupId;
        return Pages.Count(p => p.LogicalPageGroupId == groupId) > 1;
    }

    private async Task OnAddChapterStart(int pageIndex)
    {
        await OnChapterStartAdded.InvokeAsync(pageIndex);
    }

    private async Task OnRemoveChapterStart(int pageIndex)
    {
        await OnChapterStartRemoved.InvokeAsync(pageIndex);
    }

    private async Task OnGroupWithPreviousClicked(int pageIndex)
    {
        await OnGroupWithPrevious.InvokeAsync(pageIndex);
    }

    private async Task OnUngroupClicked(int pageIndex)
    {
        await OnUngroupPage.InvokeAsync(pageIndex);
    }

    private async Task OnDefaultVariantClicked(int pageIndex)
    {
        await OnDefaultVariantSelected.InvokeAsync(pageIndex);
    }

    private async Task OnTogglePageExcluded(int pageIndex)
    {
        if (pageIndex < 0 || pageIndex >= Pages.Count)
        {
            return;
        }

        await OnPageExclusionChanged.InvokeAsync((pageIndex, !Pages[pageIndex].IsExcluded));
    }

    private async Task OnImportClicked()
    {
        await OnImport.InvokeAsync();
    }

    private async Task OnBackClicked()
    {
        await OnBack.InvokeAsync();
    }
}
