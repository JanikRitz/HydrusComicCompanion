@using HydrusComicCompanion.Components.ImportWizard.State
@inject NavigationManager NavigationManager

@{
    var importedCount = Items.Count(item => item.Status == ImportWizardState.QueueItemStatus.Imported);
    var failedCount = Items.Count(item => item.Status == ImportWizardState.QueueItemStatus.Failed);
    var severity = failedCount == 0
        ? Severity.Success
        : importedCount == 0 ? Severity.Error : Severity.Warning;
}

<MudStack Spacing="3">
    <MudAlert Severity="@severity" Variant="Variant.Outlined">
        @if (failedCount == 0)
        {
            <text>Import complete! @importedCount comic(s) imported successfully.</text>
        }
        else if (importedCount == 0)
        {
            <text>Import finished. All @failedCount comic(s) failed.</text>
        }
        else
        {
            <text>Import finished. @importedCount imported, @failedCount failed.</text>
        }
    </MudAlert>

    @if (Items.Count > 0)
    {
        <MudDataGrid T="ImportWizardState.QueuedComic"
                     Items="@Items"
                     Filterable="true"
                     QuickFilter="@ItemsQuickFilter"
                     Dense="true"
                     Hover="true">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle2">Import results</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_itemsSearch"
                              Placeholder="Filter results"
                              Adornment="Adornment.Start"
                              Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Class="mt-0" />
            </ToolBarContent>
            <Columns>
                <TemplateColumn Title="Status" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@GetStatusIcon(context.Item.Status)"
                                     Color="@GetStatusColor(context.Item.Status)"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.caption">@context.Item.Status</MudText>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.DisplayName" Title="Comic" />
                <PropertyColumn Property="x => x.Error" Title="Error" />
                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                    <CellTemplate>
                        @if (context.Item.Status == ImportWizardState.QueueItemStatus.Imported && context.Item.ImportedSeriesId > 0)
                        {
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => ViewTitle(context.Item.ImportedSeriesId))">
                                View
                            </MudButton>
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ImportWizardState.QueuedComic" />
            </PagerContent>
        </MudDataGrid>
    }

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick="OnImportAnotherClicked">Import Another</MudButton>
    </MudStack>
</MudStack>

@code {
    [Parameter]
    public IReadOnlyList<ImportWizardState.QueuedComic> Items { get; set; } = [];

    [Parameter]
    public EventCallback OnImportAnother { get; set; }

    private string _itemsSearch = string.Empty;

    private Func<ImportWizardState.QueuedComic, bool> ItemsQuickFilter => item =>
    {
        if (string.IsNullOrWhiteSpace(_itemsSearch))
        {
            return true;
        }

        return item.DisplayName.Contains(_itemsSearch, StringComparison.OrdinalIgnoreCase)
            || item.Status.ToString().Contains(_itemsSearch, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(item.Error) && item.Error.Contains(_itemsSearch, StringComparison.OrdinalIgnoreCase));
    };

    private static string GetStatusIcon(ImportWizardState.QueueItemStatus status) => status switch
    {
        ImportWizardState.QueueItemStatus.Imported => Icons.Material.Filled.CheckCircle,
        ImportWizardState.QueueItemStatus.Failed => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.RemoveCircleOutline
    };

    private static Color GetStatusColor(ImportWizardState.QueueItemStatus status) => status switch
    {
        ImportWizardState.QueueItemStatus.Imported => Color.Success,
        ImportWizardState.QueueItemStatus.Failed => Color.Error,
        _ => Color.Default
    };

    private void ViewTitle(int seriesId)
    {
        NavigationManager.NavigateTo($"/comic/{seriesId}");
    }

    private async Task OnImportAnotherClicked()
    {
        await OnImportAnother.InvokeAsync();
    }
}
